{% extends 'base.html.twig' %}

{% block title %}Mes produits - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-boxes me-2"></i>Mes produits</h2>
        <a href="{{ path('vendeur_produit_new') }}" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>Ajouter un produit
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="card">
        <div class="card-body">
            {% if produits|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-success">
                        <tr>
                            <th>Image</th>
                            <th>Nom</th>
                            <th>Catégorie</th>
                            <th>Prix</th>
                            <th>Stock</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for produit in produits %}
                        <tr>
                            <td>
                                {% if produit.image %}
                                    <img src="{{ asset(produit.image) }}" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                {% else %}
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                        <i class="fas fa-image text-muted"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td>{{ produit.nom }}</td>
                            <td>{{ produit.categorie.nom|default('-') }}</td>
                            <td>{{ produit.prix|number_format(0, ',', ' ') }} FCA</td>
                            <td>
                                {% if produit.quantite > 0 %}
                                    <span class="badge bg-success">{{ produit.quantite }}</span>
                                {% else %}
                                    <span class="badge bg-danger">Rupture</span>
                                {% endif %}
                            </td>
                            <td>{{ produit.createdAt|date('d/m/Y') }}</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a href="{{ path('vendeur_produit_edit', {id: produit.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="{{ path('vendeur_produit_delete', {id: produit.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="text-center py-5">
                <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
                <h4>Vous n'avez pas encore de produits</h4>
                <p class="text-muted">Commencez par ajouter votre premier produit agricole !</p>
                <a href="{{ path('vendeur_produit_new') }}" class="btn btn-success btn-lg">
                    <i class="fas fa-plus me-2"></i>Ajouter un produit
                </a>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

