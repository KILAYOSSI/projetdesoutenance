{% extends 'base.html.twig' %}

{% block title %}Dashboard Vendeur - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    .navbar, footer { display: none !important; }
    body { margin-top: 0 !important; background: #f5f5f5; }
    main { margin-top: 0 !important; }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2 p-0" style="background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%); min-height: 100vh; position: fixed;">
            <div class="p-3 text-white border-bottom border-secondary">
                <h5 class="m-0"><i class="fas fa-leaf me-2"></i>KilysAgri</h5>
            </div>
            <div class="p-3">
                <div class="text-uppercase text-muted small fw-bold mb-2">Principal</div>
                <a href="{{ path('vendeur_dashboard') }}" class="d-block text-white text-decoration-none py-2">
                    <i class="fas fa-th-large me-2"></i>Dashboard
                </a>
                <a href="{{ path('vendeur_produits') }}" class="d-block text-white-50 text-decoration-none py-2">
                    <i class="fas fa-box me-2"></i>Mes Produits
                </a>
                <a href="{{ path('vendeur_commandes') }}" class="d-block text-white-50 text-decoration-none py-2">
                    <i class="fas fa-shopping-cart me-2"></i>Commandes
                </a>
                
                <div class="text-uppercase text-muted small fw-bold mt-4 mb-2">Gestion</div>
                <a href="{{ path('kyc_status') }}" class="d-block text-white-50 text-decoration-none py-2">
                    <i class="fas fa-id-card me-2"></i>Mon KYC
                </a>
                
                <div class="text-uppercase text-muted small fw-bold mt-4 mb-2">Compte</div>
                <a href="{{ path('app_home') }}" class="d-block text-white-50 text-decoration-none py-2">
                    <i class="fas fa-arrow-left me-2"></i>Retour au site
                </a>
                <a href="{{ path('app_logout') }}" class="d-block text-white-50 text-decoration-none py-2">
                    <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                </a>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="col-md-10 offset-md-2 p-4">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm">
                <h4 class="m-0"><i class="fas fa-store me-2 text-success"></i>Mon Espace Vendeur</h4>
                <div class="d-flex align-items-center">
                    <a href="{{ path('messagerie_index') }}" class="btn btn-outline-secondary position-relative me-3" title="Messages">
                        <i class="fas fa-bell"></i>
                        {% if unreadMessages > 0 %}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            {{ unreadMessages }}
                        </span>
                        {% endif %}
                    </a>
                    <div class="d-flex align-items-center">
                        <div class="text-end me-3">
                            <div class="fw-bold">{{ app.user.nomComplet|default(app.user.email) }}</div>
                            <small class="text-muted">Vendeur</small>
                        </div>
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            {{ app.user.nomComplet|default(app.user.email)|slice(0, 2)|upper }}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Stats Cards -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-success mb-2"><i class="fas fa-box fa-2x"></i></div>
                            <h3 class="mb-0">{{ produits|length }}</h3>
                            <small class="text-muted">Produits en vente</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-primary mb-2"><i class="fas fa-shopping-cart fa-2x"></i></div>
                            <h3 class="mb-0">{{ commandes|length }}</h3>
                            <small class="text-muted">Commandes reçues</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-warning mb-2"><i class="fas fa-dollar-sign fa-2x"></i></div>
                            <h3 class="mb-0">{{ revenus|number_format(0, ',', ' ') }}</h3>
                            <small class="text-muted">Revenus (FCA)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-info mb-2"><i class="fas fa-shield-alt fa-2x"></i></div>
                            {% if app.user.isKycValidated %}
                                <h3 class="mb-0 text-success">Validé</h3>
                            {% else %}
                                <h3 class="mb-0 text-warning">En attente</h3>
                            {% endif %}
                            <small class="text-muted">Statut KYC</small>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Actions -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <a href="{{ path('vendeur_produit_new') }}" class="text-decoration-none">
                        <div class="card border-0 shadow-sm h-100 text-center p-4">
                            <i class="fas fa-plus-circle fa-2x text-success mb-2"></i>
                            <div class="text-dark">Nouveau produit</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="{{ path('vendeur_produits') }}" class="text-decoration-none">
                        <div class="card border-0 shadow-sm h-100 text-center p-4">
                            <i class="fas fa-boxes fa-2x text-primary mb-2"></i>
                            <div class="text-dark">Gérer produits</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="{{ path('vendeur_commandes') }}" class="text-decoration-none">
                        <div class="card border-0 shadow-sm h-100 text-center p-4">
                            <i class="fas fa-clipboard-list fa-2x text-info mb-2"></i>
                            <div class="text-dark">Voir commandes</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="{{ path('kyc_status') }}" class="text-decoration-none">
                        <div class="card border-0 shadow-sm h-100 text-center p-4">
                            <i class="fas fa-id-card fa-2x text-warning mb-2"></i>
                            <div class="text-dark">Mon KYC</div>
                        </div>
                    </a>
                </div>
            </div>
            
            <!-- Commandes -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0">Commandes récentes</h5>
                </div>
                <div class="card-body p-0">
                    {% if commandes|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Commande</th>
                                    <th>Client</th>
                                    <th>Montant</th>
                                    <th>Statut</th>
                                    <th>Date</th>
                                    <th class="pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for commande in commandes|slice(0, 10) %}
                                <tr>
                                    <td class="ps-4"><strong>#{{ commande.id }}</strong></td>
                                    <td>{{ commande.utilisateur.nomComplet|default(commande.utilisateur.email) }}</td>
                                    <td><strong>{{ commande.total|number_format(0, ',', ' ') }} FCA</strong></td>
                                    <td>
                                        {% if commande.status == 'en_attente' %}
                                            <span class="badge bg-warning text-dark">En attente</span>
                                        {% elseif commande.status == 'confirme' %}
                                            <span class="badge bg-success">Confirmée</span>
                                        {% elseif commande.status == 'en_cours' %}
                                            <span class="badge bg-primary">En cours</span>
                                        {% elseif commande.status == 'livre' %}
                                            <span class="badge bg-info text-dark">Livrée</span>
                                        {% elseif commande.status == 'annule' or commande.status == 'annulé' %}
                                            <span class="badge bg-danger">Annulé</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ commande.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ commande.dateCommande|date('d/m/Y') }}</td>
                                    <td class="pe-4">
                                        <a href="{{ path('commande_details', {id: commande.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="fas fa-shopping-basket fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Aucune commande pour le moment</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

