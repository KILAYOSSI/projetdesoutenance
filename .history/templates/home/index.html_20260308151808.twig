{% extends 'base.html.twig' %}

{% block title %}Accueil - KilysAgri{% endblock %}

{% block body %}
<!-- Hero Section Romantique -->
<section class="hero-romantic">
    <div class="hero-overlay"></div>
    <div class="hero-particles">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    <div class="container position-relative">
        <div class="row min-vh-100 align-items-center">
            <div class="col-lg-7">
                <div class="hero-content">
                    <span class="hero-badge wow fadeInDown" data-wow-delay="0.2s">
                        <i class="fas fa-seedling me-2"></i> L'Agriculture Durable au Benin
                    </span>
                    <h1 class="hero-title wow fadeInUp" data-wow-delay="0.4s">
                        Cultivons Ensemble <br>
                        <span class="text-gradient">L'Avenir</span> de Notre Terre
                    </h1>
                    <p class="hero-subtitle wow fadeInUp" data-wow-delay="0.6s">
                        Decouvrez une marketplace authentique ou les producteurs locaux partagent leurs treasures. 
                        Des produits frais, naturels et pleine de vie directement de nos campagnes beninoises.
                    </p>
                    <div class="hero-buttons wow fadeInUp" data-wow-delay="0.8s">
                        <a href="{{ path('produits_index') }}" class="btn btn-romantic btn-lg me-3">
                            <i class="fas fa-leaf me-2"></i>Explorer les Produits
                        </a>
                        <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-user-plus me-2"></i>Rejoindre la Communute
                        </a>
                    </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="hero-visual wow fadeInRight" data-wow-delay="0.6s">
                    <div class="floating-card card-1">
                        <div class="card-icon">
                            <i class="fas fa-seedling"></i>
                        </div>
                        <span>Produits 100% Locaux</span>
                    </div>
                    <div class="floating-card card-2">
                        <div class="card-icon">
                            <i class="fas fa-heart"></i>
                        </div>
                        <span>Commerce Ethique</span>
                    </div>
                    <div class="floating-card card-3">
                        <div class="card-icon">
                            <i class="fas fa-truck"></i>
                        </div>
                        <span>Livraison Rapide</span>
                    </div>
            </div>
    </div>
    <div class="scroll-indicator">
        <span>Decouvrez</span>
        <div class="mouse">
            <div class="wheel"></div>
    </div>
</section>

<!-- Section Emotions -->
<section class="emotions-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="section-title-romantic wow fadeInUp">
                    <span class="title-decoration">✨</span>
                    Une Experience Unique
                    <span class="title-decoration">✨</span>
                </h2>
                <p class="section-subtitle wow fadeInUp" data-wow-delay="0.2s">
                    Chaque produit raconte une histoire. Celle de nos terres, de nos producteurs et de notre passion pour l'agriculture.
                </p>
            </div>
        <div class="row g-4 mt-4">
            <div class="col-md-4">
                <div class="emotion-card wow fadeInUp" data-wow-delay="0.1s">
                    <div class="emotion-icon">
                        <i class="fas fa-sun"></i>
                    </div>
                    <h3>Fraicheur Garantie</h3>
                    <p>Des produits cueillis avec amour et livré dans les meilleurs delais</p>
                </div>
            <div class="col-md-4">
                <div class="emotion-card wow fadeInUp" data-wow-delay="0.2s">
                    <div class="emotion-icon">
                        <i class="fas fa-hands-helping"></i>
                    </div>
                    <h3>Soutien Local</h3>
                    <p>Chaque achat aide nos producteurs a continuer leur noble mission</p>
                </div>
            <div class="col-md-4">
                <div class="emotion-card wow fadeInUp" data-wow-delay="0.3s">
                    <div class="emotion-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h3>Qualite Superieure</h3>
                    <p>Des produits selectionnes avec soin pour votre satisfaction</p>
                </div>
        </div>
</section>

<!-- Section Decouverte -->
<section class="discovery-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="discovery-content wow fadeInLeft">
                    <span class="discovery-tag">Plongez dans l'univers</span>
                    <h2>Des Produits qui <span class="text-success">Font Rever</span></h2>
                    <p class="discovery-text">
                        Laissez-vous tenter par notre selection de produits agricoles de qualite. 
                        Legumes, fruits, cereales... Tout ce que la nature offre de meilleur au Benin.
                    </p>
                    <ul class="discovery-list">
                        <li><i class="fas fa-check-circle text-success me-2"></i> Fruits et legumes de saison</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Cereales et legumes secs</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Produits transformes maison</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Epices et aromates</li>
                    </ul>
                    <div class="discovery-buttons mt-4">
                        <a href="{{ path('produits_index') }}" class="btn btn-success btn-lg">
                            <i class="fas fa-compass me-2"></i>Parcourir le Catalogue
                        </a>
                    </div>
            </div>
            <div class="col-lg-6">
                <div class="discovery-gallery wow fadeInRight">
                    <div class="gallery-main">
                        <img src="https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=600" alt="Marche agricultural" class="img-fluid rounded-4">
                    </div>
                    <div class="gallery-grid">
                        <img src="https://images.unsplash.com/photo-1518977676601-b53f82ber39?w=300" alt="Legumes frais" class="rounded-3">
                        <img src="https://images.unsplash.com/photo-1610832958506-aa56368176cf?w=300" alt="Fruits exotiques" class="rounded-3">
                    </div>
            </div>
    </div>
</section>

<!-- Section Communaute -->
<section class="community-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="section-title-white wow fadeInUp">
                    <span class="heart-icon">❤️</span>
                    Rejoignez la Revolution Agricole
                    <span class="heart-icon">❤️</span>
                </h2>
                <p class="section-subtitle-white wow fadeInUp" data-wow-delay="0.2s">
                   Vous etes producteur? Vous souhaitez acheter local? 
                    Notre plateforme connecte les deux mondes pour un commerce plus humain.
                </p>
            </div>
        <div class="row g-4 mt-5">
            <div class="col-md-6">
                <div class="community-card buyer-card wow fadeInUp" data-wow-delay="0.1s">
                    <div class="card-icon-wrapper">
                        <i class="fas fa-shopping-basket"></i>
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 50px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
}

.btn-primary-romantic {
    background: linear-gradient(135deg, #198754, #20c997);
    color: white;
    border: none;
    box-shadow: 0 10px 30px rgba(25, 135, 84, 0.3);
}

.btn-primary-romantic:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(25, 135, 84, 0.4);
    color: white;
}

.btn-outline-romantic {
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
}

.btn-outline-romantic:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
    transform: translateY(-3px);
}

/* Hero Image */
.hero-image-container {
    position: relative;
    animation: slideUp 0.8s ease-out 0.3s both;
}

.hero-image {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: 30px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);
}

.hero-image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    height: 90%;
    background: linear-gradient(135deg, rgba(25, 135, 84, 0.3), rgba(32, 201, 151, 0.2));
    border-radius: 30px;
    filter: blur(40px);
    z-index: -1;
}

/* Scroll Indicator */
.scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    letter-spacing: 2px;
    animation: bounce 2s infinite;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
}

.scroll-indicator i {
    font-size: 1.25rem;
}

/* ==========================================================================
   ROMANTIC FEATURES SECTION
   ========================================================================== */
.features-romantic {
    padding: 6rem 0;
    background: linear-gradient(180deg, #0f3460 0%, #1a1a2e 100%);
    position: relative;
}

.features-romantic::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(32, 201, 151, 0.5), transparent);
}

.section-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #20c997;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 1rem;
}

.section-title-romantic {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
}

.section-subtitle-romantic {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
}

/* Feature Cards */
.feature-card-romantic {
    position: relative;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
}

.feature-card-romantic::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #198754, #20c997, #fdcb6e);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.feature-card-romantic:hover {
    transform: translateY(-8px);
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
}

.feature-card-romantic:hover::before {
    transform: scaleX(1);
}

.feature-icon-romantic {
    width: 70px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(25, 135, 84, 0.2), rgba(32, 201, 151, 0.1));
    border-radius: 20px;
    margin-bottom: 1.5rem;
    font-size: 1.75rem;
    color: #20c997;
}

.feature-title-romantic {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.75rem;
}

.feature-text-romantic {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 0;
}

/* ==========================================================================
   CATEGORIES PREVIEW - ROMANTIC
   ========================================================================== */
.categories-preview {
    padding: 6rem 0;
    background: #1a1a2e;
}

.category-card-romantic {
    position: relative;
    height: 280px;
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-card-romantic:hover {
    transform: scale(1.03);
}

.category-card-romantic img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.category-card-romantic:hover img {
    transform: scale(1.1);
}

.category-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(26, 26, 46, 0.95) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
}

.category-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.25rem;
}

.category-count {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
}

.category-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: white;
    opacity: 0;
    transform: translateX(-10px);
