<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}KilysAgri - Marketplace Agricole{% endblock %}</title>
        <meta name="description" content="Plateforme agricole de confiance pour connecter producteurs et acheteurs">
        
        <!-- Favicon -->
        <link rel="icon" type="image/x-icon" href="{{ asset('images/zooll.jpeg') }}">
        
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <!-- Font Awesome -->
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
        
        <!-- Custom CSS -->
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        
        {% block stylesheets %}{% endblock %}
        
        <style>
            :root {
                --primary: #198754;
                --primary-dark: #146c43;
                --primary-light: #20c997;
                --accent: #fdcb6e;
            }
            
            body {
                font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            }
            
            /* NAVBAR STYLE */
            .navbar-kilysagri {
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
                box-shadow: 0 2px 20px rgba(25, 135, 84, 0.15);
                padding: 0.75rem 0;
            }
            
            .navbar-kilysagri .navbar-brand {
                font-weight: 800;
                font-size: 1.5rem;
                color: white !important;
                letter-spacing: -0.5px;
            }
            
            .navbar-kilysagri .nav-link {
                color: rgba(255, 255, 255, 0.9) !important;
                font-weight: 500;
                font-size: 0.95rem;
                padding: 0.5rem 1rem !important;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }
            
            .navbar-kilysagri .nav-link:hover {
                color: white !important;
                background-color: rgba(255, 255, 255, 0.15);
            }
            
            .navbar-kilysagri .nav-link.active {
                background-color: rgba(255, 255, 255, 0.2);
                color: white !important;
            }
            
            /* Bouton connexion */
            .btn-connexion {
                background-color: rgba(255, 255, 255, 0.2);
                color: white;
                border: 2px solid rgba(255, 255, 255, 0.3);
                font-weight: 600;
                padding: 0.5rem 1.25rem;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }
            
            .btn-connexion:hover {
                background-color: white;
                color: var(--primary);
            }
            
            /* Bouton inscription */
            .btn-inscription {
                background-color: var(--accent);
                color: #1a1a2e;
                font-weight: 600;
                padding: 0.5rem 1.25rem;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }
            
            .btn-inscription:hover {
                background-color: #f5b041;
                color: #1a1a2e;
                transform: translateY(-2px);
            }
            
            /* USER DROPDOWN */
            .user-menu-link {
                background-color: rgba(255, 255, 255, 0.15);
                border-radius: 0.5rem;
                padding: 0.4rem 0.75rem !important;
            }
            
            .dropdown-menu {
                opacity: 1 !important;
                visibility: visible !important;
                background-color: white !important;
                border: none;
                border-radius: 1rem;
                box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15) !important;
                padding: 0.75rem;
                min-width: 220px;
                margin-top: 0.5rem;
            }
            
            .dropdown-menu .dropdown-item {
                padding: 0.75rem 1rem;
                color: #2d3436 !important;
                font-weight: 500;
                font-size: 0.95rem;
                border-radius: 0.5rem;
                margin-bottom: 0.25rem;
                transition: all 0.2s ease;
            }
            
            .dropdown-menu .dropdown-item:hover {
                background-color: var(--primary) !important;
                color: white !important;
                padding-left: 1.25rem;
            }
            
            .dropdown-menu .dropdown-item.text-danger:hover {
                background-color: #dc3545 !important;
            }
            
            .dropdown-menu .dropdown-item i {
                width: 20px;
                text-align: center;
            }
            
            /* USER ICON */
            .user-avatar {
                width: 32px;
                height: 32px;
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 600;
                font-size: 0.875rem;
            }
            
            /* ALERTS */
            .alert {
                border: none;
                border-radius: 1rem;
                padding: 1rem 1.5rem;
            }
            
            .alert-success {
                background-color: rgba(25, 135, 84, 0.1);
                color: #198754;
            }
            
            .alert-danger {
                background-color: rgba(220, 53, 69, 0.1);
                color: #dc3545;
            }
            
            .alert-warning {
                background-color: rgba(255, 193, 7, 0.1);
                color: #856404;
            }
            
            /* FOOTER */
            .footer-kilysagri {
                background: linear-gradient(135deg, #1a1a2e 0%, #2d3436 100%);
                color: rgba(255, 255, 255, 0.7);
                padding: 4rem 0 2rem;
            }
            
            .footer-kilysagri h5 {
                color: white;
                font-weight: 600;
                margin-bottom: 1.5rem;
            }
            
            .footer-kilysagri a {
                color: rgba(255, 255, 255, 0.6);
                text-decoration: none;
                transition: all 0.2s ease;
            }
            
            .footer-kilysagri a:hover {
                color: var(--primary-light);
                padding-left: 5px;
            }
            
            .footer-bottom {
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                padding-top: 2rem;
                margin-top: 3rem;
                text-align: center;
                color: rgba(255, 255, 255, 0.4);
            }
            
            /* MAIN CONTENT */
            main {
                min-height: calc(100vh - 200px);
                padding-top: 1rem;
            }
        </style>
    </head>
    <body>
        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-kilysagri fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" href="{{ path('app_home') }}">
                    <i class="fas fa-leaf me-2"></i>KilysAgri
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                <i class="fas fa-home me-1"></i> Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('produits_index') }}">
                                <i class="fas fa-seedling me-1"></i> Produits
                            </a>
                        </li>
                        {% if app.user and app.user.canSell() %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('vendeur_dashboard') }}">
                                <i class="fas fa-store me-1"></i> Mon Espace
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                    
                    <ul class="navbar-nav align-items-center">
                        <!-- Panier -->
                        <li class="nav-item me-2">
                            <a class="nav-link position-relative" href="{{ path('panier_index') }}">
                                <i class="fas fa-shopping-cart"></i>
                                <span class="ms-1">Panier</span>
                            </a>
                        </li>
                        
                        {% if app.user %}
                            <!-- Menu utilisateur connecté -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-menu-link" href="#" id="userDropdown" 
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-avatar me-1">
                                        {{ app.user.email|first|upper }}
                                    </span>
                                    <span class="d-none d-md-inline">{{ app.user.email|split('@')[0] }}</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    {% if app.user.canSell() %}
                                    <li><a class="dropdown-item" href="{{ path('vendeur_dashboard') }}">
                                        <i class="fas fa-tachometer-alt"></i> Dashboard
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('vendeur_produits') }}">
                                        <i class="fas fa-boxes"></i> Mes produits
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('vendeur_commandes') }}">
                                        <i class="fas fa-clipboard-list"></i> Commandes
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    {% else %}
                                    <li><a class="dropdown-item" href="{{ path('kyc_submit') }}">
                                        <i class="fas fa-store"></i> Devenir vendeur
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    {% endif %}
                                    <li><a class="dropdown-item" href="{{ path('commande_mes_commandes') }}">
                                        <i class="fas fa-shopping-bag"></i> Mes achats
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('kyc_status') }}">
                                        <i class="fas fa-id-card"></i> Mon KYC
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                        <i class="fas fa-sign-out-alt"></i> Déconnexion
                                    </a></li>
                                </ul>
                            </li>
                        {% else %}
                            <!-- Boutons connexion/inscription -->
                            <li class="nav-item">
                                <a href="{{ path('app_login') }}" class="btn btn-connexion btn-sm me-2">
                                    <i class="fas fa-sign-in-alt me-1"></i> Connexion
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="{{ path('app_register') }}" class="btn btn-inscription btn-sm">
                                    <i class="fas fa-user-plus me-1"></i> Inscription
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Messages flash -->
        <div style="margin-top: 80px;">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        </div>

        <!-- Main Content -->
        <main>
            {% block body %}{% endblock %}
        </main>
        
        <!-- FOOTER -->
        <footer class="footer-kilysagri">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
                        <h5><i class="fas fa-leaf me-2 text-success"></i>KilysAgri</h5>
                        <p>Votre plateforme agricole de confiance pour connecter producteurs et acheteurs. Achetez et vendez en toute sécurité.</p>
                    </div>
                    <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                        <h5>Liens rapides</h5>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('app_home') }}"><i class="fas fa-angle-right me-2"></i>Accueil</a></li>
                            <li><a href="{{ path('produits_index') }}"><i class="fas fa-angle-right me-2"></i>Produits</a></li>
                            <li><a href="{{ path('app_login') }}"><i class="fas fa-angle-right me-2"></i>Connexion</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                        <h5>Contact</h5>
                        <ul class="list-unstyled">
                            <li><i class="fas fa-envelope me-2"></i>contact@kilysagri.com</li>
                            <li><i class="fas fa-phone me-2"></i>+229 00 00 00 00</li>
                            <li><i class="fas fa-map-marker me-2"></i>Cotonou, Benin</li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5>Suivez-nous</h5>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-white-50"><i class="fab fa-facebook fa-lg"></i></a>
                            <a href="#" class="text-white-50"><i class="fab fa-instagram fa-lg"></i></a>
                            <a href="#" class="text-white-50"><i class="fab fa-twitter fa-lg"></i></a>
                            <a href="#" class="text-white-50"><i class="fab fa-whatsapp fa-lg"></i></a>
                        </div>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p class="mb-0">&copy; {{ "now"|date("Y") }} KilysAgri. Tous droits réservés.</p>
                </div>
            </div>
        </footer>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>

