{% extends 'base.html.twig' %}

{% block title %}Mon panier - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5">
    <h2 class="mb-4"><i class="fas fa-shopping-cart me-2"></i>Mon panier</h2>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning">{{ message }}</div>
    {% endfor %}

    {% if produits|length > 0 %}
    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-body">
                    {% for item in produits %}
                    <div class="row align-items-center mb-3 pb-3 border-bottom">
                        <div class="col-md-2">
                            {% if item.produit.image %}
                                <img src="{{ asset(item.produit.image) }}" class="img-fluid rounded" style="max-height: 80px; object-fit: cover;">
                            {% else %}
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 80px;">
                                    <i class="fas fa-image text-muted"></i>
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-md-4">
                            <h5 class="mb-1">{{ item.produit.nom }}</h5>
                            <p class="text-muted mb-0 small">{{ item.produit.categorie.nom|default('') }}</p>
                            <p class="text-success mb-0"><strong>{{ item.produit.prix|number_format(0, ',', ' ') }} FCA</strong></p>
                        </div>
                        <div class="col-md-3">
                            <form method="post" action="{{ path('panier_modifier', {id: item.produit.id}) }}">
                                <div class="input-group">
                                    <input type="number" name="quantite" value="{{ item.quantite }}" min="1" max="{{ item.produit.quantite }}" class="form-control">
                                    <button type="submit" class="btn btn-outline-secondary">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                            </form>
                        </div>
                        <div class="col-md-2 text-end">
                            <strong>{{ item.sousTotal|number_format(0, ',', ' ') }} FCA</strong>
                        </div>
                        <div class="col-md-1 text-end">
                            <a href="{{ path('panier_supprimer', {id: item.produit.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Retirer ce produit du panier ?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            
            <a href="{{ path('panier_vider') }}" class="btn btn-outline-danger" onclick="return confirm('Vider le panier ?')">
                <i class="fas fa-trash me-2"></i>Vider le panier
            </a>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Récapitulatif</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Nombre d'articles</span>
                        <strong>{{ produits|length }}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Quantité totale</span>
                        <strong>{{ produits|reduce((carry, item) => carry + item.quantite) }}</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="h5 mb-0">Total</span>
                        <span class="h5 mb-0 text-success">{{ total|number_format(0, ',', ' ') }} FCA</span>
                    </div>
                    
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('commande_passer') }}" class="btn btn-success w-100 btn-lg">
                            <i class="fas fa-check-circle me-2"></i>Passer la commande
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-primary w-100 btn-lg">
                            <i class="fas fa-sign-in-alt me-2"></i>Connectez-vous pour commander
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h4>Votre panier est vide</h4>
            <p class="text-muted">Découvrez nos produits agricoles !</p>
            <a href="{{ path('produits_index') }}" class="btn btn-success btn-lg">
                <i class="fas fa-store me-2"></i>Voir les produits
            </a>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}

