{% extends 'base.html.twig' %}

{% block title %}Connexion - KilysAgri{% endblock %}

{% block footer %}{% endblock %}

{% block stylesheets %}
<style>
    .login-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #198754 0%, #0d5c3d 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    .login-container {
        display: flex;
        max-width: 900px;
        width: 100%;
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    
    .login-image {
        flex: 1;
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 40px;
        color: white;
        position: relative;
        overflow: hidden;
    }
    
    .login-image::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
    }
    
    .login-image i {
        font-size: 80px;
        margin-bottom: 20px;
        position: relative;
        z-index: 1;
    }
    
    .login-image h2 {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 10px;
        position: relative;
        z-index: 1;
    }
    
    .login-image p {
        font-size: 14px;
        opacity: 0.9;
        text-align: center;
        position: relative;
        z-index: 1;
    }
    
    .login-form {
        flex: 1;
        padding: 50px 40px;
    }
    
    .login-form .brand {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 30px;
    }
    
    .login-form .brand i {
        font-size: 32px;
        color: #198754;
    }
    
    .login-form .brand span {
        font-size: 24px;
        font-weight: 700;
        color: #198754;
        margin-left: 10px;
    }
    
    .login-form h3 {
        text-align: center;
        color: #333;
        margin-bottom: 30px;
        font-weight: 600;
    }
    
    .form-floating {
        margin-bottom: 20px;
    }
    
    .form-floating .form-control {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 12px 15px;
        height: auto;
        transition: all 0.3s;
    }
    
    .form-floating .form-control:focus {
        border-color: #198754;
        box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
    }
    
    .form-floating label {
        color: #666;
        padding: 12px 15px;
    }
    
    .btn-login {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        border: none;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s;
        margin-top: 10px;
    }
    
    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(25, 135, 84, 0.3);
    }
    
    .divider {
        display: flex;
        align-items: center;
        margin: 25px 0;
    }
    
    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e0e0e0;
    }
    
    .divider span {
        padding: 0 15px;
        color: #666;
        font-size: 14px;
    }
    
    .register-link {
        text-align: center;
        margin-top: 20px;
        color: #666;
    }
    
    .register-link a {
        color: #198754;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.3s;
    }
    
    .register-link a:hover {
        color: #146c43;
        text-decoration: underline;
    }
    
    .forgot-password {
        text-align: right;
        margin-top: -10px;
        margin-bottom: 20px;
    }
    
    .forgot-password a {
        color: #198754;
        font-size: 14px;
        text-decoration: none;
    }
    
    .forgot-password a:hover {
        text-decoration: underline;
    }
    
    .alert {
        border-radius: 10px;
        padding: 12px 15px;
        margin-bottom: 20px;
    }
    
    @media (max-width: 768px) {
        .login-container {
            flex-direction: column;
        }
        
        .login-image {
            padding: 30px;
        }
        
        .login-image i {
            font-size: 50px;
        }
        
        .login-image h2 {
            font-size: 22px;
        }
        
        .login-form {
            padding: 30px 20px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-container">
        <div class="login-image">
            <i class="fas fa-leaf"></i>
            <h2>Bienvenue sur KilysAgri</h2>
            <p>Votre marketplace agricole de confiance au Benin. Achetez et vendez des produits frais directement des producteurs locaux.</p>
        </div>
        
        <div class="login-form">
            <div class="brand">
                <i class="fas fa-leaf"></i>
                <span>KilysAgri</span>
            </div>
            
            <h3>Se connecter</h3>
            
            {% if error %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    {% if error.messageKey == 'Invalid credentials.' %}
                        Email ou mot de passe incorrect. Veuillez vérifier vos identifiants.
                    {% else %}
                        {{ error.message|trans(error.messageData, 'security') }}
                    {% endif %}
                </div>
            {% endif %}
            
            {% for flash_error in app.flashes('error') %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ flash_error }}
                </div>
            {% endfor %}
            
            <form method="post">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                
                <div class="form-floating">
                    <input type="email" class="form-control" id="email" name="email" placeholder="Email" value="{{ last_username ?? '' }}" required>
                    <label for="email"><i class="fas fa-envelope me-2"></i>Email</label>
                </div>
                
                <div class="form-floating">
                    <input type="password" class="form-control" id="password" name="password" placeholder="Mot de passe" required>
                    <label for="password"><i class="fas fa-lock me-2"></i>Mot de passe</label>
                </div>
                
                <div class="forgot-password">
                    <a href="#">Mot de passe oublié ?</a>
                </div>
                
                <button type="submit" class="btn btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Se connecter
                </button>
            </form>
            
            <div class="divider">
                <span>OU</span>
            </div>
            
            <div class="register-link">
                <p>Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a></p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
