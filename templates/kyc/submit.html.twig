{% extends 'base.html.twig' %}

{% block title %}Vérification d'identité - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-id-card me-2"></i>Vérification d'identité (KYC)</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info">
                        <h5><i class="fas fa-info-circle me-2"></i>Pourquoi cette vérification ?</h5>
                        <p class="mb-0">Pour devenir vendeur sur KilysAgri et publier vos produits agricoles, vous devez d'abord vérifier votre identité.</p>
                    </div>

                    <div class="alert alert-warning">
                        <h5><i class="fas fa-exclamation-triangle me-2"></i>Documents requis</h5>
                        <ul class="mb-0">
                            <li>Une pièce d'identité valide (CNI, passeport ou permis de conduire)</li>
                            <li>Photo selfie en direct avec votre pièce d'identité</li>
                        </ul>
                    </div>

                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'id': 'kyc_form', 'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="mb-4">
                        <h5 class="border-bottom pb-2 mb-3">Informations de la pièce</h5>
                        <div class="mb-3">
                            {{ form_label(form.typePiece) }}
                            {{ form_widget(form.typePiece, {'attr': {'class': 'form-select'}}) }}
                            <div class="text-danger">{{ form_errors(form.typePiece) }}</div>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.numeroPiece) }}
                            {{ form_widget(form.numeroPiece, {'attr': {'class': 'form-control'}}) }}
                            <div class="text-danger">{{ form_errors(form.numeroPiece) }}</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="border-bottom pb-2 mb-3">Photos de la pièce d'identité</h5>
                        
                        <!-- Photo Recto - Camera ONLY -->
                        <div class="mb-3">
                            {{ form_label(form.photoPieceRecto) }}
                            <div class="upload-box" onclick="document.getElementById('kyc_photoPieceRecto').click()">
                                <i class="fas fa-camera fa-2x text-muted"></i>
                                <p class="mb-0 text-muted">Cliquez pour prendre la photo avec la caméra</p>
                                <div id="preview_piece_recto_container"></div>
                            </div>
                            {{ form_widget(form.photoPieceRecto, {'attr': {'style': 'display: none;', 'onchange': "previewFile(this, 'preview_piece_recto_container')", 'capture': 'environment'}}) }}
                            <div class="text-danger">{{ form_errors(form.photoPieceRecto) }}</div>
                        </div>

                        <!-- Photo Verso - Camera ONLY -->
                        <div class="mb-3">
                            {{ form_label(form.photoPieceVerso) }}
                            <div class="upload-box" onclick="document.getElementById('kyc_photoPieceVerso').click()">
                                <i class="fas fa-camera fa-2x text-muted"></i>
                                <p class="mb-0 text-muted">Cliquez pour prendre la photo avec la caméra (optionnel)</p>
                                <div id="preview_piece_verso_container"></div>
                            </div>
                            {{ form_widget(form.photoPieceVerso, {'attr': {'style': 'display: none;', 'onchange': "previewFile(this, 'preview_piece_verso_container')", 'capture': 'environment'}}) }}
                            <div class="text-danger">{{ form_errors(form.photoPieceVerso) }}</div>
                        </div>
                    </div>

                    <!-- Photo Selfie - Caméra uniquement -->
                    <div class="mb-4">
                        <h5 class="border-bottom pb-2 mb-3">Photo Selfie *</h5>
                        <div class="alert alert-danger">
                            <i class="fas fa-camera me-2"></i>
                            <strong>Photo obligatoire en direct!</strong> Vous devez prendre votre photo maintenant avec la caméra. L'accès à la galerie est interdit.
                        </div>
                        
                        <div class="text-center mb-3">
                            <video id="video" autoplay playsinline style="max-width: 100%; max-height: 300px; border-radius: 8px; border: 2px solid #dee2e6; display: none;"></video>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="button" id="startCamera" class="btn btn-primary" onclick="startCamera()">
                                <i class="fas fa-video me-2"></i>Activer la caméra
                            </button>
                            <button type="button" id="takePhoto" class="btn btn-success" onclick="takePhoto()" style="display: none;">
                                <i class="fas fa-camera me-2"></i>Prendre la photo
                            </button>
                            <button type="button" id="retakePhoto" class="btn btn-warning" onclick="retakePhoto()" style="display: none;">
                                <i class="fas fa-redo me-2"></i>Reprendre la photo
                            </button>
                        </div>

                        <div class="mt-3 text-center">
                            <canvas id="canvas" style="display: none;"></canvas>
                            <img id="selfiePreview" style="max-width: 100%; max-height: 300px; border-radius: 8px; border: 2px solid #198754; display: none;">
                        </div>
                        
                        {# Photo Selfie - Champ caché du formulaire (caméra uniquement) #}
                        {{ form_widget(form.photoSelfie, {'attr': {'id': 'photoSelfie'}}) }}
                        <div class="text-danger">{{ form_errors(form.photoSelfie) }}</div>
                        <div id="selfie_error" class="text-danger small mt-2" style="display: none;">Veuillez prendre une photo selfie</div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="{{ path('app_home') }}" class="btn btn-secondary me-md-2">Annuler</a>
                        <button type="submit" class="btn btn-success btn-lg" onclick="return validateForm()">
                            <i class="fas fa-paper-plane me-2"></i>Soumettre ma demande
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.upload-box {
    border: 2px dashed #dee2e6;
    border-radius: 8px;
    padding: 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
}
.upload-box:hover {
    border-color: #198754;
    background-color: #f8f9fa;
}
.preview-img {
    max-width: 100%;
    max-height: 200px;
    border-radius: 4px;
    margin-top: 10px;
}
</style>

<script>
let stream = null;

async function startCamera() {
    try {
        stream = await navigator.mediaDevices.getUserMedia({ 
            video: { 
                facingMode: 'user',
                width: { ideal: 1280 },
                height: { ideal: 720 }
            } 
        });
        const video = document.getElementById('video');
        video.srcObject = stream;
        video.style.display = 'block';
        document.getElementById('startCamera').style.display = 'none';
        document.getElementById('takePhoto').style.display = 'block';
    } catch (err) {
        alert('Erreur: Impossible d\'accéder à la caméra. Veuillez autoriser l\'accès à la caméra.');
        console.error(err);
    }
}

function takePhoto() {
    const video = document.getElementById('video');
    const canvas = document.getElementById('canvas');
    const selfiePreview = document.getElementById('selfiePreview');
    
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    
    const ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0);
    
    const dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    
    selfiePreview.src = dataUrl;
    selfiePreview.style.display = 'block';
    document.getElementById('photoSelfie').value = dataUrl;
    
    // Stop camera
    if (stream) {
        stream.getTracks().forEach(track => track.stop());
        stream = null;
    }
    video.style.display = 'none';
    
    document.getElementById('takePhoto').style.display = 'none';
    document.getElementById('retakePhoto').style.display = 'block';
    document.getElementById('selfie_error').style.display = 'none';
}

function retakePhoto() {
    document.getElementById('selfiePreview').style.display = 'none';
    document.getElementById('video').style.display = 'block';
    document.getElementById('photoSelfie').value = '';
    document.getElementById('takePhoto').style.display = 'block';
    document.getElementById('retakePhoto').style.display = 'none';
    document.getElementById('startCamera').style.display = 'block';
    document.getElementById('takePhoto').style.display = 'none';
}

function previewFile(input, previewId) {
    const container = document.getElementById(previewId);
    const file = input.files[0];
    
    if (file) {
        // Check file type
        if (!file.type.match('image.*')) {
            alert('Veuillez sélectionner une image valide');
            input.value = '';
            return;
        }
        
        const reader = new FileReader();
        reader.onload = function(e) {
            container.innerHTML = '<img src="' + e.target.result + '" class="preview-img">';
        };
        reader.readAsDataURL(file);
    }
}

function validateForm() {
    const selfie = document.getElementById('photoSelfie').value;
    const rectoInput = document.getElementById('kyc_photoPieceRecto');
    
    if (!rectoInput || !rectoInput.files || !rectoInput.files[0]) {
        alert('Veuillez télécharger la photo de votre pièce (recto)');
        return false;
    }
    
    if (!selfie) {
        document.getElementById('selfie_error').style.display = 'block';
        alert('Veuillez prendre une photo selfie');
        return false;
    }
    
    return true;
}
</script>
{% endblock %}

