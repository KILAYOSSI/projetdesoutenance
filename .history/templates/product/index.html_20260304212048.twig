<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catalogue Produits - KilysAgri</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .product-card { transition: all 0.3s ease; overflow: hidden; }
        .product-card:hover { transform: translateY(-8px); box-shadow: 0 15px 40px rgba(0,0,0,0.15) !important; }
        .product-img { height: 220px; object-fit: contain; }
        .price-tag { font-size: 1.5rem; font-weight: 700; }
        .category-pill { transition: all 0.3s ease; }
        .category-pill:hover { background-color: rgba(25, 135, 84, 0.15); transform: scale(1.05); }
        .search-box { border-radius: 50px; }
        .search-box:focus { border-color: #198754; box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25); }
        .btn-success { background-color: #198754; border-color: #198754; }
        .btn-success:hover { background-color: #157347; }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="bg-success text-white py-4 shadow">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h1 class="h2 mb-1"><i class="fas fa-leaf me-2"></i><strong>KilysAgri</strong></h1>
                    <p class="mb-0 opacity-75">Votre marketplace agricole de confiance</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a href="/" class="text-white text-decoration-none me-3"><i class="fas fa-home me-1"></i>Accueil</a>
                    <a href="#" class="text-white text-decoration-none me-3"><i class="fas fa-shopping-cart me-1"></i>Panier</a>
                    <a href="#" class="text-white text-decoration-none"><i class="fas fa-user me-1"></i>Compte</a>
                </div>
        </div>
    </header>

    <!-- Search Section -->
    <section class="bg-light py-4 border-bottom">
        <div class="container">
            <div class="row g-3 align-items-center">
                <div class="col-md-7">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 search-box" placeholder="Rechercher un produit..." id="searchInput">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="categoryFilter">
                        <option value="">Toutes les catégories</option>
                        {% for categorie in categories %}
                            <option value="{{ categorie.id }}">{{ categorie.nom }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" onclick="filterProducts()">
                        <i class="fas fa-filter me-1"></i>Filtrer
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Category Navigation -->
    <section class="py-4">
        <div class="container">
            <div class="d-flex flex-wrap justify-content-center gap-2">
                <a href="{{ path('produits_index') }}" class="btn btn-success btn-sm category-pill px-4">Tous</a>
                {% for categorie in categories %}
                    <a href="{{ path('produits_categorie', {id: categorie.id}) }}" class="btn btn-outline-success btn-sm category-pill px-4">{{ categorie.nom }}</a>
                {% endfor %}
            </div>
    </section>

    <!-- Products Grid -->
    <main class="py-4">
        <div class="container">
            <div class="row g-4" id="productsGrid">
                {% for produit in produits %}
                <div class="col-sm-6 col-lg-4 col-xl-3 product-item" data-category="{{ produit.categorie ? produit.categorie.id : '' }}" data-name="{{ produit.nom|lower }}">
                    <div class="card h-100 shadow-sm product-card border-0">
                        <div class="position-relative">
                            {% if produit.image %}
                                <img src="{{ asset(produit.image) }}" class="card-img-top p-3 product-img" alt="{{ produit.nom }}">
                            {% else %}
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                    <i class="fas fa-image text-muted fa-4x"></i>
                                </div>
                            {% endif %}
                            <div class="position-absolute top-0 start-0 p-2">
                                {% if produit.quantite > 0 %}
                                    <span class="badge bg-success">En stock</span>
                                {% else %}
                                    <span class="badge bg-danger">Rupture</span>
                                {% endif %}
                            </div>
                        <div class="card-body">
                            {% if produit.categorie %}
                                <span class="badge bg-success-subtle text-success mb-2">{{ produit.categorie.nom }}</span>
                            {% endif %}
                            <h5 class="card-title fw-bold">{{ produit.nom }}</h5>
                            <p class="card-text text-muted small">{{ produit.description|slice(0, 70) }}{% if produit.description|length > 70 %}...{% endif %}</p>
                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <div>
                                    <span class="price-tag text-success">{{ produit.prix|number_format(0, ',', ' ') }} €</span>
                                    <small class="text-muted d-block">TTC</small>
                                </div>
                                <span class="badge bg-light text-dark"><i class="fas fa-box me-1"></i>{{ produit.quantite }}</span>
                            </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="d-grid gap-2">
                                <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn btn-success btn-lg fw-bold{% if produit.quantite == 0 %} disabled{% endif %}">
                                    <i class="fas fa-cart-plus me-2"></i>Ajouter au panier
                                </a>
                            </div>
                    </div>
                {% else %}
                <div class="col-12 text-center py-5">
                    <i class="fas fa-box-open text-muted fa-4x mb-3"></i>
                    <h4 class="text-muted">Aucun produit disponible</h4>
                    <p class="text-muted">Découvrez bientôt notre catalogue</p>
                </div>
                {% endfor %}
            </div>
    </main>

    <!-- Features -->
    <section class="bg-light py-5 border-top">
        <div class="container">
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 70px; height: 70px;"><i class="fas fa-truck fa-2x"></i></div>
                    <h5 class="mt-3 fw-bold">Livraison rapide</h5>
                    <p class="text-muted mb-0">Livraison dans toute la région</p>
                </div>
                <div class="col-md-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 70px; height: 70px;"><i class="fas fa-shield-alt fa-2x"></i></div>
                    <h5 class="mt-3 fw-bold">Paiement sécurisé</h5>
                    <p class="text-muted mb-0">Transactions 100% sécurisées</p>
                </div>
                <div class="col-md-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 70px; height: 70px;"><i class="fas fa-headset fa-2x"></i></div>
                    <h5 class="mt-3 fw-bold">Support 24/7</h5>
                    <p class="text-muted mb-0"> Assistance disponible</p>
                </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3 mb-md-0">
                    <h5><strong>KilysAgri</strong></h5>
                    <p class="text-muted small">Votre plateforme agricole de confiance.</p>
                </div>
                <div class="col-md-4 mb-3 mb-md-0">
                    <h5>Liens rapides</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-muted text-decoration-none">À propos</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Contact</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">CGV</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>Contact</h5>
                    <ul class="list-unstyled text-muted small">
                        <li><i class="fas fa-envelope me-2"></i>contact@kilysagri.com</li>
                        <li><i class="fas fa-phone me-2"></i>+225 00 00 00 00</li>
                        <li><i class="fas fa-map-marker me-2"></i>Côte d'Ivoire</li>
                    </ul>
                </div>
            <hr class="bg-secondary">
            <div class="text-center text-muted small">&copy; {{ "now"|date("Y") }} KilysAgri. Tous droits réservés.</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('searchInput').addEventListener('keyup', filterProducts);
        document.getElementById('categoryFilter').addEventListener('change', filterProducts);
        
        function filterProducts() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const categoryId = document.getElementById('categoryFilter').value;
            const products = document.querySelectorAll('.product-item');
            
            products.forEach(product => {
                const name = product.dataset.name;
                const category = product.dataset.category;
                const matchesSearch = name.includes(searchTerm);
                const matchesCategory = !categoryId || category === categoryId;
                
                product.style.display = (matchesSearch && matchesCategory) ? '' : 'none';
            });
        }
    </script>
</body>
</html>
</parameter>
</create_file>
