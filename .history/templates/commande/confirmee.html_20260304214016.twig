{% extends 'base.html.twig' %}

{% block title %}Commande confirmée - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-success">
                <div class="card-header bg-success text-white text-center py-4">
                    <i class="fas fa-check-circle fa-4x mb-3"></i>
                    <h3>Merci pour votre commande !</h3>
                </div>
                <div class="card-body text-center">
                    <p class="lead">Votre commande a été passée avec succès.</p>
                    
                    <div class="alert alert-light border">
                        <h5>Numéro de commande: #{{ commande.id }}</h5>
                        <p class="mb-0">Montant total: <strong class="text-success">{{ commande.montantTotal|number_format(0, ',', ' ') }} FCA</strong></p>
                    </div>

                    <p>Vous recevrez une confirmation par email. Les vendeurs ont été informés de votre commande et preparent la livraison.</p>

                    <div class="d-grid gap-2 col-md-6 mx-auto mt-4">
                        <a href="{{ path('commande_details', {id: commande.id}) }}" class="btn btn-primary">
                            <i class="fas fa-eye me-2"></i>Voir les détails
                        </a>
                        <a href="{{ path('commande_mes_commandes') }}" class="btn btn-outline-primary">
                            <i class="fas fa-list me-2"></i>Mes commandes
                        </a>
                        <a href="{{ path('produits_index') }}" class="btn btn-success">
                            <i class="fas fa-store me-2"></i>Continuer vos achats
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

