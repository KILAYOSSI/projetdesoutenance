{% extends 'base.html.twig' %}

{% block title %}Inscription - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="fas fa-leaf fa-3x text-success"></i>
                        <h2 class="mt-3">Créer un compte</h2>
                        <p class="text-muted">Rejoignez KilysAgri</p>
                    </div>

                    {% for flash_error in app.flashes('verify_email_error') %}
                        <div class="alert alert-danger">{{ flash_error }}</div>
                    {% endfor %}

                    {% for flash_success in app.flashes('success') %}
                        <div class="alert alert-success">{{ flash_success }}</div>
                    {% endfor %}

                    {{ form_start(registrationForm) }}
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.nomComplet, 'Nom complet') }}
                            {{ form_widget(registrationForm.nomComplet, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.nomComplet) }}
                        </div>
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.telephone, 'Téléphone') }}
                            {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.telephone) }}
                        </div>
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.email, 'Email') }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.confirmPassword, 'Confirmer le mot de passe') }}
                            {{ form_widget(registrationForm.confirmPassword, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.confirmPassword) }}
                        </div>

                        <div class="mb-3 form-check">
                            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions", {'attr': {'class': 'form-check-label'}}) }}
                        </div>
                        {{ form_errors(registrationForm.agreeTerms) }}

                        <button type="submit" class="btn btn-success w-100 py-2">
                            <i class="fas fa-user-plus me-2"></i>Créer mon compte
                        </button>
                    {{ form_end(registrationForm) }}

                    <hr>
                    <p class="text-center mb-0">
                        Déjà un compte? <a href="{{ path('app_login') }}" class="text-success">Se connecter</a>
                    </p>
                </div>
        </div>
</div>
{% endblock %}
