{% extends 'base.html.twig' %}

{% block title %}Produits - KilysAgri{% endblock %}

{% block body %}
<div class="container py-4" style="margin-top: 70px;">
    <h2 class="mb-4">Tous nos produits</h2>
    
    <!-- Categories -->
    <div class="mb-4">
        <a href="{{ path('produits_index') }}" class="btn btn-outline-success {% if not categorie_active %}active{% endif %}">Tous</a>
        {% for categorie in categories %}
            <a href="{{ path('produits_categorie', {id: categorie.id}) }}" class="btn btn-outline-success">
                {{ categorie.nom }}
            </a>
        {% endfor %}
    </div>
    
    {% if produits|length > 0 %}
        <div class="row">
            {% for produit in produits %}
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card h-100">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="card-img-top" style="height: 180px; object-fit: cover;">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center bg-secondary" style="height: 180px;">
                                <i class="fas fa-image text-white fa-3x"></i>
                            </div>
                        {% endif %}
                        <div class="card-body">
                            {% if produit.categorie %}
                                <small class="text-success">{{ produit.categorie.nom }}</small>
                            {% endif %}
                            <h5 class="card-title">{{ produit.nom }}</h5>
                            <p class="text-success fw-bold">{{ produit.prix|number_format(0, ',', ' ') }} FCA</p>
                            {% if produit.quantite > 0 %}
                                <span class="badge bg-success">En stock</span>
                            {% else %}
                                <span class="badge bg-danger">Rupture</span>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-white">
                            <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn btn-success w-100">
                                <i class="fas fa-eye me-1"></i>Voir
                            </a>
                        </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-seedling fa-4x text-muted mb-3"></i>
            <h4>Aucun produit trouvé</h4>
            <a href="{{ path('produits_index') }}" class="btn btn-success">Voir tous les produits</a>
        </div>
    {% endif %}
</div>
{% endblock %}
