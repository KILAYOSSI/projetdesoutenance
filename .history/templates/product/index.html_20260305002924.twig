{% extends 'base.html.twig' %}

{% block title %}Catalogue Produits - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    /* Breadcrumb */
    .breadcrumb-section {
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        padding: 1rem 0;
        margin-top: 70px;
    }
    
    .breadcrumb {
        margin-bottom: 0;
        background: transparent;
    }
    
    .breadcrumb-item a {
        color: rgba(255,255,255,0.8) !important;
        text-decoration: none;
    }
    
    .breadcrumb-item a:hover {
        color: white !important;
    }
    
    .breadcrumb-item.active {
        color: white !important;
    }
    
    .breadcrumb-item + .breadcrumb-item::before {
        color: rgba(255,255,255,0.6);
    }
    
    /* Search Section */
    .search-section {
        background: #f8f9fa;
        padding: 2rem 0;
        border-bottom: 1px solid #e9ecef;
    }
    
    .search-box {
        border-radius: 0.75rem;
        border: 2px solid #e9ecef;
        padding: 0.875rem 1.25rem;
        transition: all 0.2s ease;
    }
    
    .search-box:focus {
        border-color: #198754;
        box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
    }
    
    .filter-select {
        border-radius: 0.75rem;
        border: 2px solid #e9ecef;
        padding: 0.875rem 1.25rem;
    }
    
    .filter-select:focus {
        border-color: #198754;
        box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
    }
    
    /* Category Pills */
    .category-nav {
        padding: 1.5rem 0;
        background: white;
        border-bottom: 1px solid #e9ecef;
    }
    
    .category-pill {
        padding: 0.625rem 1.25rem;
        border-radius: 2rem;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    
    .category-pill:hover {
        transform: translateY(-2px);
    }
    
    /* Products Grid */
    .products-section {
        padding: 3rem 0;
        background: #fafafa;
        min-height: 60vh;
    }
    
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    
    .section-header h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    
    /* Product Card */
    .product-card {
        background: white;
        border: none;
        border-radius: 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
    }
    
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.12);
    }
    
    .product-image-wrapper {
        position: relative;
        height: 220px;
        overflow: hidden;
        background: #f8f9fa;
    }
    
    .product-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    
    .product-card:hover .product-image-wrapper img {
        transform: scale(1.08);
    }
    
    .product-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.375rem 0.875rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .badge-in-stock {
        background: #198754;
        color: white;
    }
    
    .badge-out-stock {
        background: #dc3545;
        color: white;
    }
    
    .product-body {
        padding: 1.25rem;
    }
    
    .product-category {
        font-size: 0.75rem;
        font-weight: 600;
        color: #198754;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
    }
    
    .product-title {
        font-size: 1.125rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }
    
    .product-description {
        font-size: 0.875rem;
        color: #6c757d;
        line-height: 1.5;
        margin-bottom: 1rem;
    }
    
    .product-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid #e9ecef;
    }
    
    .product-price {
        font-size: 1.375rem;
        font-weight: 800;
        color: #198754;
    }
    
    .product-price span {
        font-size: 0.75rem;
        font-weight: 500;
        color: #6c757d;
    }
    
    .product-stock {
        font-size: 0.875rem;
        color: #6c757d;
    }
    
    .product-stock i {
        margin-right: 0.25rem;
    }
    
    /* Buttons */
    .btn-add-cart {
        background: #198754;
        color: white;
        border: none;
        padding: 0.875rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
    }
    
    .btn-add-cart:hover {
        background: #146c43;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(25, 135, 84, 0.3);
    }
    
    .btn-add-cart:disabled {
        background: #6c757d;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }
    
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }
    
    .empty-state i {
        font-size: 5rem;
        color: #dee2e6;
        margin-bottom: 1.5rem;
    }
    
    .empty-state h4 {
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    
    .empty-state p {
        color: #adb5bd;
    }
    
    /* Features Bar */
    .features-bar {
        background: white;
        padding: 1.5rem 0;
        border-top: 1px solid #e9ecef;
    }
    
    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .feature-icon {
        width: 48px;
        height: 48px;
        background: rgba(25, 135, 84, 0.1);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #198754;
        font-size: 1.25rem;
    }
    
    .feature-text h6 {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 0;
    }
    
    .feature-text p {
        font-size: 0.875rem;
        color: #6c757d;
        margin-bottom: 0;
    }
    
    /* Animations */
    .fade-in {
        animation: fadeIn 0.5s ease-out;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
{% endblock %}

{% block body %}

<!-- Breadcrumb -->
<nav class="breadcrumb-section">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                <li class="breadcrumb-item active" aria-current="page">Produits</li>
            </ol>
        </nav>
    </div>
</nav>

<!-- Search Section -->
<section class="search-section">
    <div class="container">
        <div class="row g-3 align-items-center">
            <div class="col-lg-7">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control search-box border-start-0" 
                           placeholder="Rechercher un produit..." 
                           id="searchInput">
                </div>
            </div>
            <div class="col-lg-3">
                <select class="form-select filter-select" id="categoryFilter">
                    <option value="">Toutes les catégories</option>
                    {% for categorie in categories %}
                        <option value="{{ categorie.id }}">{{ categorie.nom }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-lg-2">
                <button class="btn btn-primary w-100" onclick="filterProducts()">
                    <i class="fas fa-filter me-1"></i> Filtrer
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Category Navigation -->
<nav class="category-nav">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a href="{{ path('produits_index') }}" class="btn btn-primary category-pill">
                <i class="fas fa-th-large me-1"></i> Tous
            </a>
            {% for categorie in categories %}
                <a href="{{ path('produits_categorie', {id: categorie.id}) }}" 
                   class="btn btn-outline-success category-pill">
                    {{ categorie.nom }}
                </a>
            {% endfor %}
        </div>
    </div>
</nav>

<!-- Products Grid -->
<main class="products-section">
    <div class="container">
        <div class="section-header">
            <h2><i class="fas fa-seedling me-2 text-success"></i>Nos Produits</h2>
            <span class="text-muted">{{ produits|length }} produit(s) disponible(s)</span>
        </div>
        
        <div class="row g-4" id="productsGrid">
            {% for produit in produits %}
            <div class="col-sm-6 col-lg-4 col-xl-3 product-item fade-in" 
                 data-category="{{ produit.categorie ? produit.categorie.id : '' }}" 
                 data-name="{{ produit.nom|lower }}"
                 style="animation-delay: {{ loop.index * 0.05 }}s">
                <div class="product-card">
                    <div class="product-image-wrapper">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                <i class="fas fa-image text-muted fa-3x"></i>
                            </div>
                        {% endif %}
                        {% if produit.quantite > 0 %}
                            <span class="product-badge badge-in-stock">
                                <i class="fas fa-check-circle me-1"></i>En stock
                            </span>
                        {% else %}
                            <span class="product-badge badge-out-stock">
                                <i class="fas fa-times-circle me-1"></i>Rupture
                            </span>
                        {% endif %}
                    </div>
                    <div class="product-body">
                        {% if produit.categorie %}
                            <div class="product-category">{{ produit.categorie.nom }}</div>
                        {% endif %}
                        <h5 class="product-title">{{ produit.nom }}</h5>
                        <p class="product-description">
                            {{ produit.description|slice(0, 80) }}{% if produit.description|length > 80 %}...{% endif %}
                        </p>
                        <div class="product-footer">
                            <div>
                                <div class="product-price">
                                    {{ produit.prix|number_format(0, ',', ' ') }} <span>FCA</span>
                                </div>
                            </div>
                            <div class="product-stock">
                                <i class="fas fa-box"></i> {{ produit.quantite }}
                            </div>
                        </div>
                        <a href="{{ path('produits_detail', {id: produit.id}) }}" 
                           class="btn btn-add-cart mt-3{% if produit.quantite == 0 %} disabled{% endif %}">
                            <i class="fas fa-cart-plus me-2"></i>
                            {% if produit.quantite > 0 %}Ajouter au panier{% else %}Indisponible{% endif %}
                        </a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12">
                <div class="empty-state">
                    <i class="fas fa-box-open"></i>
                    <h4>Aucun produit disponible</h4>
                    <p>Découvrez bientôt notre catalogue de produits agricoles</p>
                    <a href="{{ path('app_home') }}" class="btn btn-primary mt-3">
                        <i class="fas fa-home me-2"></i>Retour à l'accueil
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</main>

<!-- Features Bar -->
<section class="features-bar">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-truck"></i>
                    </div>
                    <div class="feature-text">
                        <h6>Livraison rapide</h6>
                        <p>Dans toute la région</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div class="feature-text">
                        <h6>Paiement sécurisé</h6>
                        <p>Transactions 100% sécurisées</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <div class="feature-text">
                        <h6>Support 24/7</h6>
                        <p>Assistance disponible</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}

{% block javascripts %}
<script>
    document.getElementById('searchInput').addEventListener('keyup', filterProducts);
    document.getElementById('categoryFilter').addEventListener('change', filterProducts);
    
    function filterProducts() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const categoryId = document.getElementById('categoryFilter').value;
        const products = document.querySelectorAll('.product-item');
        
        products.forEach(product => {
            const name = product.dataset.name;
            const category = product.dataset.category;
            const matchesSearch = name.includes(searchTerm);
            const matchesCategory = !categoryId || category === categoryId;
            
            if (matchesSearch && matchesCategory) {
                product.style.display = '';
                product.classList.add('fade-in');
            } else {
                product.style.display = 'none';
            }
        });
    }
</script>
{% endblock %}

