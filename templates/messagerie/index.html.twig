{% extends 'base.html.twig' %}

{% block title %}Messagerie - KilysAgri{% endblock %}

{% block body %}
<main class="messaging-page" style="margin-top: 70px;">
    <div class="container-fluid py-4">
        <div class="row">
            <!-- Conversations List -->
            <div class="col-md-4">
                <div class="conversations-list-card">
                    <div class="conversations-header">
                        <h3><i class="fas fa-comments"></i> Messages</h3>
                    </div>
                    
                    <div class="conversations-list">
                        {% if conversations|length > 0 %}
                            {% for conversation in conversations %}
                                {% set otherUser = conversation.getOtherParticipant(app.user) %}
                                {% set lastMessage = conversation.getLastMessage() %}
                                {% set unreadCount = conversation.getUnreadCountForUser(app.user) %}
                                <a href="{{ path('messagerie_conversation', {id: conversation.id}) }}" class="conversation-item {% if unreadCount > 0 %}unread{% endif %}">
                                    <div class="conversation-avatar">
                                        <i class="fas fa-user"></i>
                                    </div>
                                    <div class="conversation-info">
                                        <div class="conversation-name">
                                            {{ otherUser.nomComplet ?: otherUser.email|split('@')[0] }}
                                        </div>
                                        <div class="conversation-preview">
                                            {% if lastMessage %}
                                                {% if lastMessage.sender.id == app.user.id %}
                                                    <span class="you">Vous:</span>
                                                {% endif %}
                                                {{ lastMessage.content|slice(0, 40) }}{% if lastMessage.content|length > 40 %}...{% endif %}
                                            {% else %}
                                                <span class="no-messages">Aucun message</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="conversation-meta">
                                        {% if conversation.lastMessageAt %}
                                            <span class="conversation-time">
                                                {% if conversation.lastMessageAt|date('d/m/Y') == 'now'|date('d/m/Y') %}
                                                    {{ conversation.lastMessageAt|date('H:i') }}
                                                {% else %}
                                                    {{ conversation.lastMessageAt|date('d/m') }}
                                                {% endif %}
                                            </span>
                                        {% endif %}
                                        {% if unreadCount > 0 %}
                                            <span class="unread-badge">{{ unreadCount }}</span>
                                        {% endif %}
                                    </div>
                                </a>
                            {% endfor %}
                        {% else %}
                            <div class="no-conversations">
                                <i class="fas fa-envelope-open"></i>
                                <p>Aucune conversation</p>
                                <small>Contactez un vendeur pour démarrer une conversation</small>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- Chat Area -->
            <div class="col-md-8">
                <div class="chat-welcome-card">
<div class="chat-welcome-content">
                        <div class="messaging-logo">
                            <div class="logo-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                            <div class="logo-chat-dots">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                        <h3>Bienvenue dans votre messagerie</h3>
                        <p>Sélectionnez une conversation pour commencer à discuter</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
.messaging-page {
    background: #f5f5f5;
    min-height: 90vh;
}

.conversations-list-card,
.chat-welcome-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    overflow: hidden;
    height: calc(100vh - 120px);
}

.conversations-header {
    padding: 20px;
    background: linear-gradient(135deg, #198754 0%, #146c43 100%);
    color: white;
}

.conversations-header h3 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
}

.conversations-header h3 i {
    margin-right: 10px;
}

.conversations-list {
    height: calc(100% - 70px);
    overflow-y: auto;
}

.conversation-item {
    display: flex;
    align-items: center;
    padding: 15px 20px;
    border-bottom: 1px solid #f0f0f0;
    text-decoration: none;
    color: #333;
    transition: background 0.2s;
}

.conversation-item:hover {
    background: #f8f9fa;
}

.conversation-item.unread {
    background: #e8f5e9;
}

.conversation-item.unread .conversation-name {
    font-weight: 700;
}

.conversation-avatar {
    width: 50px;
    height: 50px;
    background: #e9ecef;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
    flex-shrink: 0;
}

.conversation-avatar i {
    color: #6c757d;
    font-size: 1.2rem;
}

.conversation-info {
    flex: 1;
    min-width: 0;
}

.conversation-name {
    font-weight: 600;
    margin-bottom: 4px;
    color: #1a1a1a;
}

.conversation-preview {
    font-size: 0.85rem;
    color: #666;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.conversation-preview .you {
    color: #198754;
    margin-right: 5px;
}

.conversation-preview .no-messages {
    color: #999;
    font-style: italic;
}

.conversation-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-left: 10px;
}

.conversation-time {
    font-size: 0.75rem;
    color: #999;
    margin-bottom: 5px;
}

.unread-badge {
    background: #198754;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 10px;
    min-width: 20px;
    text-align: center;
}

.no-conversations {
    text-align: center;
    padding: 50px 20px;
    color: #999;
}

.no-conversations i {
    font-size: 3rem;
    margin-bottom: 15px;
    color: #dee2e6;
}

.no-conversations p {
    font-weight: 600;
    color: #666;
    margin-bottom: 5px;
}

.no-conversations small {
    font-size: 0.85rem;
}

.chat-welcome-card {
    display: flex;
    align-items: center;
    justify-content: center;
}

.chat-welcome-content {
    text-align: center;
    color: #666;
}

/* Custom Messaging Logo - KilysAgri */
.messaging-logo {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 30px;
}

.logo-icon {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #198754 0%, #146c43 100%);
    border-radius: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(25, 135, 84, 0.4);
    animation: float 3s ease-in-out infinite;
}

.logo-icon i {
    font-size: 3.5rem;
    color: white;
}

.logo-chat-dots {
    position: absolute;
    bottom: 0;
    right: 0;
    display: flex;
    gap: 5px;
}

.logo-chat-dots span {
    width: 12px;
    height: 12px;
    background: linear-gradient(135deg, #ffa500 0%, #ff8c00 100%);
    border-radius: 50%;
    box-shadow: 0 3px 10px rgba(255, 165, 0, 0.5);
}

.logo-chat-dots span:nth-child(1) {
    animation: bounce 1s ease-in-out infinite;
}

.logo-chat-dots span:nth-child(2) {
    animation: bounce 1s ease-in-out infinite 0.2s;
}

.logo-chat-dots span:nth-child(3) {
    animation: bounce 1s ease-in-out infinite 0.4s;
}

@keyframes float {
    0%, 100% {
        transform: translateY(0);
    }
    50% {
        transform: translateY(-10px);
    }
}

@keyframes bounce {
    0%, 100% {
        transform: translateY(0);
    }
    50% {
        transform: translateY(-8px);
    }
}

.chat-welcome-content h3 {
    font-size: 1.5rem;
    color: #1a1a1a;
    margin-bottom: 10px;
}

.chat-welcome-content p {
    font-size: 1rem;
}

@media (max-width: 768px) {
    .conversations-list-card,
    .chat-welcome-card {
        height: calc(100vh - 120px);
    }
}
</style>
{% endblock %}

