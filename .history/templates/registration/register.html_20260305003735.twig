{% extends 'base.html.twig' %}

{% block title %}Inscription - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 50%, #f8f9fa 100%);
        padding: 2rem;
    }
    
    .auth-container {
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.1);
        padding: 2.5rem;
        width: 100%;
        max-width: 500px;
    }
    
    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    
    .auth-logo {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #198754 0%, #20c997 100%);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 0.5rem 1rem rgba(25, 135, 84, 0.3);
    }
    
    .auth-logo i {
        font-size: 2.5rem;
        color: white;
    }
    
    .auth-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }
    
    .auth-header p {
        color: #6c757d;
        margin-bottom: 0;
    }
    
    .form-group {
        margin-bottom: 1.25rem;
    }
    
    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #495057;
    }
    
    .form-control, .form-select {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 2px solid #e9ecef;
        border-radius: 0.75rem;
        font-size: 1rem;
        transition: all 0.2s ease;
    }
    
    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: #198754;
        box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
    }
    
    .btn-auth {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .btn-auth:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(25, 135, 84, 0.3);
    }
    
    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        color: #6c757d;
    }
    
    .auth-footer a {
        color: #198754;
        font-weight: 600;
        text-decoration: none;
    }
    
    .auth-footer a:hover {
        text-decoration: underline;
    }
    
    .alert-danger {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border: none;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }
    
    .alert-success {
        background: rgba(25, 135, 84, 0.1);
        color: #198754;
        border: none;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }
    
    .form-check {
        display: flex;
        align-items: center;
        margin-bottom: 1.25rem;
    }
    
    .form-check-input {
        width: 1.25rem;
        height: 1.25rem;
        margin-right: 0.75rem;
        accent-color: #198754;
    }
    
    .form-check-label {
        color: #495057;
    }
    
    .form-error {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }
    
    .help-text {
        color: #6c757d;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }
    
    @media (max-width: 480px) {
        .auth-container {
            padding: 1.5rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        <div class="auth-header">
            <div class="auth-logo">
                <i class="fas fa-leaf"></i>
            </div>
            <h1>Créer un compte</h1>
            <p>Rejoignez KilysAgri dès aujourd'hui</p>
        </div>

        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="alert alert-danger" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>{{ flash_error }}
            </div>
        {% endfor %}

        {% for flash_success in app.flashes('success') %}
            <div class="alert alert-success" role="alert">
                <i class="fas fa-check-circle me-2"></i>{{ flash_success }}
            </div>
        {% endfor %}

        {{ form_start(registrationForm, {'attr': {'class': 'auth-form'}}) }}
            
            <div class="form-group">
                {{ form_label(registrationForm.email, 'Adresse email') }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Votre adresse email'}}) }}
                <div class="help-text">{{ form_help(registrationForm.email) }}</div>
                {{ form_errors(registrationForm.email) }}
            </div>
            
            <div class="form-group">
                {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Votre mot de passe'}}) }}
                <div class="help-text">Minimum 6 caractères</div>
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
            
            <div class="form-group">
                {{ form_label(registrationForm.confirmPassword, 'Confirmer le mot de passe') }}
                {{ form_widget(registrationForm.confirmPassword, {'attr': {'class': 'form-control', 'placeholder': 'Confirmez votre mot de passe'}}) }}
                {{ form_errors(registrationForm.confirmPassword) }}
            </div>

            <div class="form-check">
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation") }}
            </div>
            {{ form_errors(registrationForm.agreeTerms) }}

            <button type="submit" class="btn-auth">
                <i class="fas fa-user-plus me-2"></i>Créer mon compte
            </button>
        {{ form_end(registrationForm) }}

        <div class="auth-footer">
            <p>Déjà un compte? <a href="{{ path('app_login') }}">Se connecter</a></p>
        </div>
    </div>
</div>
{% endblock %}

