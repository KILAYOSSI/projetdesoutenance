888888888888888888888888888888{% extends 'base.html.twig' %}

{% block title %}Demande envoyée - KilysAgri{% endblock %}

{% block body %}
<main class="success-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="success-card">
                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    
                    <h1>Votre demande a été soumise !</h1>
                    
<p class="message">
                        Merci d'avoir rejoint KilysAgri. Nous avons bien reçu votre demande de devenir vendeur et vos documents d'identité.
                    </p>
                    
                    <div class="info-box">
                        <div class="info-item">
                            <i class="fas fa-clock"></i>
                            <div>
                                <strong> Temps de traitement</strong>
                                <span>Notre équipe vérifie votre demande sous 24 à 48 heures ouvrées </div>
                       .</span>
                            </div>
                        
                        <div class="info-item">
                            <i class="fas fa-envelope"></i>
                            <div>
                                <strong>Notification</strong>
                                <span>Vous recevrez un email dès que votre demande sera traitée.</span>
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <i class="fas fa-question-circle"></i>
                            <div>
                                <strong>Questions ?</strong>
                                <span>Contactez notre support à support@kilysagri.com</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="status-badge">
                        <i class="fas fa-hourglass-half"></i>
                        <span>Statut: En attente de validation</span>
                    </div>
                    
                    <div class="actions">
                        <a href="{{ path('app_home') }}" class="btn-home">
                            <i class="fas fa-home"></i>
                            Retour à l'accueil
                        </a>
                    </div>
                    
                    <p class="footer-text">
                        En attendant, vous pouvez continuer à parcourir les produits et ajouter des articles à votre panier. Votre boutique sera activée dès que votre demande sera validée par notre équipe.
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
.success-page {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 60px 0;
}

.success-card {
    background: white;
    border-radius: 20px;
    padding: 50px 40px;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
}

.success-icon {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px;
}

.success-icon i {
    font-size: 3.5rem;
    color: #28a745;
}

.success-card h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 20px;
}

.success-card .message {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 30px;
}

.info-box {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 25px;
    margin-bottom: 25px;
    text-align: left;
}

.info-item {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    align-items: flex-start;
}

.info-item:last-child {
    margin-bottom: 0;
}

.info-item i {
    width: 24px;
    color: #198754;
    font-size: 1.1rem;
    margin-top: 3px;
}

.info-item div {
    flex: 1;
}

.info-item strong {
    display: block;
    color: #1a1a1a;
    font-weight: 600;
    margin-bottom: 4px;
}

.info-item span {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
}

.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #fff3cd;
    color: #856404;
    padding: 12px 25px;
    border-radius: 30px;
    font-weight: 600;
    margin-bottom: 25px;
}

.status-badge i {
    font-size: 1.1rem;
}

.actions {
    margin-bottom: 25px;
}

.btn-home {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #198754;
    color: white;
    padding: 14px 35px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
}

.btn-home:hover {
    background: #146c43;
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(25, 135, 84, 0.3);
    color: white;
}

.footer-text {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.6;
    margin: 0;
}

@media (max-width: 768px) {
    .success-card {
        padding: 35px 25px;
    }
    
    .success-icon {
        width: 80px;
        height: 80px;
    }
    
    .success-icon i {
        font-size: 2.5rem;
    }
    
    .success-card h1 {
        font-size: 1.4rem;
    }
}
</style>
{% endblock %}

