{% extends 'base.html.twig' %}

{% block title %}Chat avec {{ otherUser.nomComplet ?: otherUser.email }} - KilysAgri{% endblock %}

{% block body %}
<main class="chat-page" style="margin-top: 70px;">
    <div class="container-fluid py-3">
        <div class="row">
            <div class="col-12 mb-3">
                <a href="{{ path('messagerie_index') }}" class="btn-back-conversations">
                    <i class="fas fa-arrow-left"></i> Retour aux messages
                </a>
            </div>
        </div>
        
        <div class="row">
            <div class="col-12">
                <div class="chat-container">
                    <div class="chat-header">
                        <div class="chat-header-logo">
                            <div class="logo-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                        </div>
                        <div class="chat-user-info">
                            <div class="chat-avatar">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="chat-user-details">
                                <div class="chat-user-name">
                                    {{ otherUser.nomComplet ?: otherUser.email|split('@')[0] }}
                                </div>
                                <div class="chat-user-status">
                                    {% if otherUser.isVendeur %}
                                        <span class="badge-vendeur"><i class="fas fa-store"></i> Vendeur</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="chat-messages" id="chatMessages">
                        {% for message in messages %}
                            {% if not message.isDeleted or message.sender.id == app.user.id %}
                            <div class="message {% if message.sender.id == app.user.id %}sent{% else %}received {% endif %}" data-id="{{ message.id }}" data-sender="{{ message.sender.id }}">
                                <div class="message-bubble" onclick="showMessageOptions(event, {{ message.id }})">
                                    <div class="message-content">{{ message.content }}</div>
                                    <div class="message-meta">
                                        <span class="message-time">
                                            {% if message.isEdited %}<i class="fas fa-pencil-alt" title="Modifié"></i> {% endif %}
                                            {{ message.createdAt|date('H:i') }}
                                        </span>
                                        {% if message.sender.id == app.user.id %}
                                            {% if message.isRead %}
                                                <i class="fas fa-check-double"></i>
                                            {% else %}
                                                <i class="fas fa-check"></i>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    
                    <div class="chat-input-area">
                        <form id="messageForm" class="message-form">
                            <input type="hidden" id="conversationId" value="{{ conversation.id }}">
                            <div class="input-group">
                                <input type="text" id="messageInput" class="form-control" placeholder="Tapez votre message..." autocomplete="off">
                                <button type="submit" class="btn-send">
                                    <i class="fas fa-paper-plane"></i>
                                </button>
                            </div>
                        </form>
                        <small class="input-hint">Les numéros de téléphone et emails ne sont pas autorisés</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Message Options Modal -->
<div class="modal fade" id="messageOptionsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Options du message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="messageOptionsBody">
            </div>
        </div>
    </div>
</div>

<!-- Edit Message Modal -->
<div class="modal fade" id="editMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Modifier le message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <textarea id="editMessageContent" class="form-control" rows="3" placeholder="Votre message..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="saveEditedMessage()">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<style>
.chat-page { background: #f5f5f5; min-height: calc(100vh - 70px); padding-bottom: 20px; }
.btn-back-conversations { display: inline-flex; align-items: center; gap: 8px; color: #198754; text-decoration: none; font-weight: 500; padding: 8px 0; }
.btn-back-conversations:hover { color: #146c43; }
.chat-container { background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden; height: calc(100vh - 180px); display: flex; flex-direction: column; }
.chat-header { padding: 15px 20px; background: linear-gradient(135deg, #198754 0%, #146c43 100%); color: white; }
.chat-header-logo { display: flex; align-items: center; gap: 15px; }
.chat-header-logo .logo-icon { width: 40px; height: 40px; background: rgba(255,255,255,0.2); border-radius: 10px; display: flex; align-items: center; justify-content: center; animation: pulse 2s ease-in-out infinite; }
.chat-header-logo .logo-icon i { font-size: 1.2rem; color: white; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
.chat-user-info { display: flex; align-items: center; }
.chat-avatar { width: 45px; height: 45px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 15px; }
.chat-avatar i { font-size: 1.2rem; }
.chat-user-details { flex: 1; }
.chat-user-name { font-weight: 600; font-size: 1.1rem; }
.chat-user-status { font-size: 0.85rem; opacity: 0.9; }
.badge-vendeur { background: rgba(255,255,255,0.2); padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; }
.chat-messages { flex: 1; overflow-y: auto; padding: 20px; background: #efedd5; display: flex; flex-direction: column; gap: 10px; }
.message { display: flex; max-width: 75%; cursor: pointer; }
.message.sent { align-self: flex-end; }
.message.received { align-self: flex-start; }
.message-bubble { padding: 10px 15px; border-radius: 18px; position: relative; word-wrap: break-word; transition: all 0.2s; }
.message-bubble:hover { opacity: 0.9; }
.message.sent .message-bubble { background: #25D366; color: white; border-bottom-right-radius: 4px; }
.message.received .message-bubble { background: white; color: #333; border-bottom-left-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.1); }
.message-content { font-size: 0.95rem; line-height: 1.4; margin-bottom: 5px; }
.message-meta { display: flex; align-items: center; gap: 5px; justify-content: flex-end; }
.message-time { font-size: 0.7rem; opacity: 0.8; }
.message-time i { font-size: 0.6rem; margin-right: 3px; }
.message.sent .message-meta i { margin-left: 4px; font-size: 0.7rem; }
.chat-input-area { padding: 15px 20px; background: white; border-top: 1px solid #f0f0f0; }
.message-form .input-group { display: flex; gap: 10px; }
.message-form input { flex: 1; padding: 12px 15px; border: 1px solid #ddd; border-radius: 25px; font-size: 0.95rem; outline: none; transition: border-color 0.3s; }
.message-form input:focus { border-color: #198754; }
.btn-send { width: 45px; height: 45px; border: none; background: #198754; color: white; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
.btn-send:hover { background: #146c43; transform: scale(1.05); }
.btn-send i { font-size: 1rem; }
.input-hint { display: block; margin-top: 8px; font-size: 0.75rem; color: #999; text-align: center; }
.chat-messages::-webkit-scrollbar { width: 6px; }
.chat-messages::-webkit-scrollbar-track { background: #f1f1f1; }
.chat-messages::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
.chat-messages::-webkit-scrollbar-thumb:hover { background: #aaa; }
@media (max-width: 768px) { .chat-container { height: calc(100vh - 130px); } .message { max-width: 85%; } }
</style>

<script>
let currentMessageId = null;

function showMessageOptions(event, messageId) {
    event.stopPropagation();
    const messageEl = document.querySelector(`.message[data-id="${messageId}"]`);
    const senderId = parseInt(messageEl.dataset.sender);
    const currentUserId = {{ app.user.id }};
    
    if (senderId !== currentUserId) return;
    
    currentMessageId = messageId;
    const modalBody = document.getElementById('messageOptionsBody');
    
    modalBody.innerHTML = `
        <button class="btn btn-outline-primary w-100 mb-2" onclick="openEditModal()">
            <i class="fas fa-edit"></i> Modifier
        </button>
        <button class="btn btn-outline-danger w-100 mb-2" onclick="deleteMessage(false)">
            <i class="fas fa-trash"></i> Supprimer pour moi
        </button>
        <button class="btn btn-outline-danger w-100" onclick="deleteMessage(true)">
            <i class="fas fa-trash-alt"></i> Supprimer pour tout le monde
        </button>
    `;
    
    const modal = new bootstrap.Modal(document.getElementById('messageOptionsModal'));
    modal.show();
}

function openEditModal() {
    const messageEl = document.querySelector(`.message[data-id="${currentMessageId}"]`);
    const contentEl = messageEl.querySelector('.message-content');
    const currentContent = contentEl.textContent;
    
    if (currentContent === 'Ce message a été supprimé') {
        alert('Ce message a déjà été supprimé');
        return;
    }
    
    document.getElementById('editMessageContent').value = currentContent;
    bootstrap.Modal.getOrCreateInstance(document.getElementById('messageOptionsModal')).hide();
    const modal = new bootstrap.Modal(document.getElementById('editMessageModal'));
    modal.show();
}

function saveEditedMessage() {
    const newContent = document.getElementById('editMessageContent').value.trim();
    
    if (!newContent) {
        alert('Le message ne peut pas être vide');
        return;
    }
    
    const formData = new FormData();
    formData.append('content', newContent);
    
    fetch('/messagerie/message/' + currentMessageId + '/edit', {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getOrCreateInstance(document.getElementById('editMessageModal')).hide();
            const messageEl = document.querySelector(`.message[data-id="${currentMessageId}"]`);
            const contentEl = messageEl.querySelector('.message-content');
            const timeEl = messageEl.querySelector('.message-time');
            contentEl.textContent = data.message.content;
            timeEl.innerHTML = `<i class="fas fa-pencil-alt" title="Modifié"></i> ${data.message.editedAt}`;
        } else {
            alert(data.error || 'Erreur lors de la modification');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Erreur lors de la modification');
    });
}

function deleteMessage(deleteForEveryone) {
    if (!confirm(deleteForEveryone ? 'Voulez-vous vraiment supprimer ce message pour tout le monde ?' : 'Voulez-vous supprimer ce message ?')) {
        return;
    }
    
    const formData = new FormData();
    formData.append('deleteForEveryone', deleteForEveryone);
    
    fetch('/messagerie/message/' + currentMessageId + '/delete', {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getOrCreateInstance(document.getElementById('messageOptionsModal')).hide();
            
            if (deleteForEveryone) {
                const messageEl = document.querySelector(`.message[data-id="${currentMessageId}"]`);
                messageEl.remove();
            } else {
                const messageEl = document.querySelector(`.message[data-id="${currentMessageId}"]`);
                const contentEl = messageEl.querySelector('.message-content');
                contentEl.textContent = 'Ce message a été supprimé';
                contentEl.style.fontStyle = 'italic';
                contentEl.style.opacity = '0.6';
            }
        } else {
            alert(data.error || 'Erreur lors de la suppression');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Erreur lors de la suppression');
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const messageForm = document.getElementById('messageForm');
    const messageInput = document.getElementById('messageInput');
    const conversationId = document.getElementById('conversationId').value;
    const chatMessages = document.getElementById('chatMessages');
    
    chatMessages.scrollTop = chatMessages.scrollHeight;
    
    messageForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const content = messageInput.value.trim();
        if (!content) return;
        
        const formData = new FormData();
        formData.append('content', content);
        
        fetch('/messagerie/send/' + conversationId, {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const messageDiv = document.createElement('div');
                messageDiv.className = 'message sent';
                messageDiv.dataset.id = data.message.id;
                messageDiv.dataset.sender = {{ app.user.id }};
                messageDiv.innerHTML = `
                    <div class="message-bubble" onclick="showMessageOptions(event, ${data.message.id})">
                        <div class="message-content">${data.message.content}</div>
                        <div class="message-meta">
                            <span class="message-time">${data.message.createdAt} <i class="fas fa-check"></i></span>
                        </div>
                    </div>
                `;
                chatMessages.appendChild(messageDiv);
                messageInput.value = '';
                chatMessages.scrollTop = chatMessages.scrollHeight;
            } else {
                alert(data.error || 'Erreur lors de l\'envoi du message');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Erreur lors de l\'envoi du message');
        });
    });
    
    setInterval(function() {
        fetch('/messagerie/api/messages/' + conversationId, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.json())
        .then(data => {
            if (data.length !== undefined) {
                const currentMessages = chatMessages.querySelectorAll('.message').length;
                
                if (data.length > currentMessages) {
                    const existingIds = Array.from(chatMessages.querySelectorAll('.message')).map(msg => msg.dataset.id);
                    
                    data.forEach(msg => {
                        if (!existingIds.includes(msg.id.toString())) {
                            const messageDiv = document.createElement('div');
                            messageDiv.className = 'message ' + (msg.isMine ? 'sent' : 'received');
                            messageDiv.dataset.id = msg.id;
                            messageDiv.dataset.sender = msg.senderId;
                            messageDiv.innerHTML = `
                                <div class="message-bubble" onclick="showMessageOptions(event, ${msg.id})">
                                    <div class="message-content">${msg.content}</div>
                                    <div class="message-meta">
                                        <span class="message-time">${msg.createdAt} ${msg.isMine ? (msg.isRead ? '<i class="fas fa-check-double"></i>' : '<i class="fas fa-check"></i>') : ''}</span>
                                    </div>
                                </div>
                            `;
                            chatMessages.appendChild(messageDiv);
                        }
                    });
                    
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
            }
        })
        .catch(error => { console.error('Polling error:', error); });
    }, 5000);
});
</script>
{% endblock %}

