{% extends 'base.html.twig' %}

{% block title %}Catégories - KilysAgri Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-tags me-2"></i>Gestion des catégories</h2>
    
    <div class="card mb-4">
        <div class="card-body">
            <form method="post" action="{{ path('admin_categorie_new') }}" class="d-flex gap-2">
                <input type="text" name="nom" class="form-control" placeholder="Nouvelle catégorie" required>
                <button type="submit" class="btn btn-success"><i class="fas fa-plus"></i> Ajouter</button>
            </form>
        </div>
    </div>
    
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for categorie in categories %}
                        <tr>
                            <td>{{ categorie.id }}</td>
                            <td>{{ categorie.nom }}</td>
                            <td>
                                <a href="{{ path('admin_categorie_delete', {id: categorie.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Êtes-vous sûr ?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="3" class="text-center">Aucune catégorie</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary mt-3">
        <i class="fas fa-arrow-left me-2"></i>Retour au dashboard
    </a>
</div>
{% endblock %}

