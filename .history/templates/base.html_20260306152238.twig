<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}KilysAgri - Marketplace Agricole{% endblock %}</title>
        <meta name="description" content="Plateforme agricole de confiance pour connecter producteurs et acheteurs">
        
        <link rel="icon" type="image/x-icon" href="{{ asset('images/zooll.jpeg') }}">
        
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
        
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        
        {% block stylesheets %}{% endblock %}
        
        <style>
            :root {
                --primary: #198754;
                --primary-dark: #146c43;
                --primary-light: #20c997;
                --accent: #fdcb6e;
            }
            
            body {
                font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            }
            
            .navbar-kilysagri {
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
                box-shadow: 0 2px 20px rgba(25, 135, 84, 0.15);
                padding: 0.75rem 0;
            }
            
            .navbar-kilysagri .navbar-brand {
                font-weight: 800;
                font-size: 1.5rem;
                color: white !important;
                letter-spacing: -0.5px;
            }
            
            .navbar-kilysagri .nav-link {
                color: rgba(255, 255, 255, 0.9) !important;
                font-weight: 500;
                font-size: 0.95rem;
                padding: 0.5rem 1rem !important;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }
            
            .navbar-kilysagri .nav-link:hover {
                color: white !important;
                background-color: rgba(255, 255, 255, 0.15);
            }
            
            .btn-connexion {
                background-color: rgba(255, 255, 255, 0.2);
                color: white;
                border: 2px solid rgba(255, 255, 255, 0.3);
                font-weight: 600;
                padding: 0.5rem 1.25rem;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }
            
            .btn-connexion:hover {
                background-color: white;
                color: var(--primary);
            }
            
            .btn-inscription {
                background-color: var(--accent);
                color: #1a1a2e;
                font-weight: 600;
                padding: 0.5rem 1.25rem;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }
            
            .btn-inscription:hover {
                background-color: #f5b041;
                color: #1a1a2e;
                transform: translateY(-2px);
            }
            
            .user-menu-link {
                background-color: rgba(255, 255, 255, 0.15);
                border-radius: 0.5rem;
                padding: 0.4rem 0.75rem !important;
            }
            
            .dropdown-menu {
                opacity: 1 !important;
                visibility: visible !important;
                background-color: white !important;
                border: none;
                border-radius: 1rem;
                box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15) !important;
                padding: 0.75rem;
                min-width: 220px;
                margin-top: 0.5rem;
            }
            
            .dropdown-menu .dropdown-item {
                padding: 0.75rem 1rem;
                color: #2d3436 !important;
                font-weight: 500;
                font-size: 0.95rem;
                border-radius: 0.5rem;
                margin-bottom: 0.25rem;
                transition: all 0.2s ease;
            }
            
            .dropdown-menu .dropdown-item:hover {
                background-color: var(--primary) !important;
                color: white !important;
                padding-left: 1.25rem;
            }
            
            .user-avatar {
                width: 32px;
                height: 32px;
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 600;
                font-size: 0.875rem;
            }
            
            .alert {
                border: none;
                border-radius: 1rem;
                padding: 1rem 1.5rem;
            }
            
            .alert-success {
                background-color: rgba(25, 135, 84, 0.1);
                color: #198754;
            }
            
            .alert-danger {
                background-color: rgba(220, 53, 69, 0.1);
                color: #dc3545;
            }
            
            .alert-warning {
                background-color: rgba(255, 193, 7, 0.1);
                color: #856404;
            }
            
            .footer-kilysagri {
                background: linear-gradient(135deg, #1a1a2e 0%, #2d3436 100%);
                color: rgba(255, 255, 255, 0.7);
                padding: 4rem 0 2rem;
            }
            
            .footer-kilysagri h5 {
                color: white;
                font-weight: 600;
                margin-bottom: 1.5rem;
            }
            
            .footer-kilysagri a {
                color: rgba(255, 255, 255, 0.6);
                text-decoration: none;
                transition: all 0.2s ease;
            }
            
            .footer-kilysagri a:hover {
                color: var(--primary-light);
                padding-left: 5px;
            }
            
            .footer-bottom {
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                padding-top: 2rem;
                margin-top: 3rem;
                text-align: center;
                color: rgba(255, 255, 255, 0.4);
            }
            
            main {
                min-height: calc(100vh - 200px);
                padding-top: 1rem;
            }
            
            /* CART BADGE */
            .cart-badge {
                position: absolute;
                top: -5px;
                right: -5px;
                background: #ffc107;
                color: #1a1a2e;
                font-size: 0.7rem;
                font-weight: 700;
                padding: 2px 6px;
                border-radius: 50%;
                min-width: 18px;
                height: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
            }
        </style>
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-kilysagri fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" href="{{ path('app_home') }}">
                    <i class="fas fa-leaf me-2"></i>KilysAgri
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                <i class="fas fa-home me-1"></i> Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('produits_index') }}">
                                <i class="fas fa-seedling me-1"></i> Produits
                            </a>
                        </li>
                        {% if app.user and app.user.canSell() %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('vendeur_dashboard') }}">
                                <i class="fas fa-store me-1"></i> Mon Espace
                            </a>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('admin_dashboard') }}" style="background: rgba(255,255,255,0.2); border-radius: 0.5rem;">
                                <i class="fas fa-cog me-1"></i> Admin
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                    
                    <ul class="navbar-nav align-items-center">
                        {% if app.user %}
                        <li class="nav-item me-2">
                            <a class="nav-link position-relative" href="{{ path('panier_index') }}" style="padding-right: 15px !important;">
                                <i class="fas fa-shopping-cart"></i>
                                <span class="ms-1">Panier</span>
                                <span class="cart-badge" id="cartBadge" style="display: none;">0</span>
                            </a>
                        </li>
                        
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-menu-link" href="#" id="userDropdown" data-bs-toggle="dropdown">
                                    <span class="user-avatar me-1">
                                        {% if app.user.nomComplet %}{{ app.user.nomComplet|first|upper }}{% else %}{{ app.user.email|first|upper }}{% endif %}
                                    </span>
                                    <span class="d-none d-md-inline">{% if app.user.nomComplet %}{{ app.user.nomComplet }}{% else %}{{ app.user.email|split('@')[0] }}{% endif %}</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    {% if app.user.canSell() %}
                                    <li><a class="dropdown-item" href="{{ path('vendeur_dashboard') }}">
                                        <i class="fas fa-tachometer-alt"></i> Dashboard
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('vendeur_produits') }}">
                                        <i class="fas fa-boxes"></i> Mes produits
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    {% else %}
                                    <li><a class="dropdown-item" href="{{ path('kyc_submit') }}">
                                        <i class="fas fa-store"></i> Devenir vendeur
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    {% endif %}
                                    <li><a class="dropdown-item" href="{{ path('commande_mes_commandes') }}">
                                        <i class="fas fa-shopping-bag"></i> Mes achats
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('kyc_status') }}">
                                        <i class="fas fa-id-card"></i> Mon KYC
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                        <i class="fas fa-sign-out-alt"></i> Deconnexion
                                    </a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a href="{{ path('app_login') }}" class="btn btn-connexion btn-sm me-2">
                                    <i class="fas fa-sign-in-alt me-1"></i> Connexion
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="{{ path('app_register') }}" class="btn btn-inscription btn-sm">
                                    <i class="fas fa-user-plus me-1"></i> Inscription
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
        </nav>

        <div style="margin-top: 80px;">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        </div>

        <main>
            {% block body %}{% endblock %}
        </main>
        
        <footer class="footer-kilysagri">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
                        <h5><i class="fas fa-leaf me-2 text-success"></i>KilysAgri</h5>
                        <p>Votre plateforme agricole de confiance pour connecter producteurs et acheteurs.</p>
                    </div>
                    <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                        <h5>Liens rapides</h5>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('app_home') }}"><i class="fas fa-angle-right me-2"></i>Accueil</a></li>
                            <li><a href="{{ path('produits_index') }}"><i class="fas fa-angle-right me-2"></i>Produits</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                        <h5>Contact</h5>
                        <ul class="list-unstyled">
                            <li><i class="fas fa-envelope me-2"></i>contact@kilysagri.com</li>
                            <li><i class="fas fa-phone me-2"></i>+229 00 00 00 00</li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5>Suivez-nous</h5>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-white-50"><i class="fab fa-facebook fa-lg"></i></a>
                            <a href="#" class="text-white-50"><i class="fab fa-instagram fa-lg"></i></a>
                            <a href="#" class="text-white-50"><i class="fab fa-whatsapp fa-lg"></i></a>
                        </div>
                <div class="footer-bottom">
                    <p class="mb-0">&copy; {{ "now"|date("Y") }} KilysAgri. Tous droits reserves.</p>
                </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        
        <script>
        // Update cart badge on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateCartBadge();
        });
        
        function updateCartBadge() {
            const badge = document.getElementById('cartBadge');
            if (!badge) return;
            
            // Fetch cart count from server
            fetch('{{ path("panier_count") }}')
                .then(response => response.json())
                .then(data => {
                    const count = data.count || 0;
                    if (count > 0) {
                        badge.textContent = count;
                        badge.style.display = 'flex';
                    } else {
                        badge.style.display = 'none';
                    }
                })
                .catch(error => {
                    console.log('Erreur panier:', error);
                    badge.style.display = 'none';
                });
        }
        
        // Function to refresh cart badge (call this after adding to cart)
        window.refreshCartBadge = function() {
            updateCartBadge();
        };
        </script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>
