{% extends 'base.html.twig' %}

{% block title %}Détails commande #{{ commande.id }} - KilysAgri Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <h2 class="mb-4">Commande #{{ commande.id }}</h2>
    
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Informations client</h5>
        </div>
        <div class="card-body">
            <p><strong>Email:</strong> {{ commande.utilisateur.email }}</p>
            <p><strong>Date:</strong> {{ commande.dateCommande|date('d/m/Y H:i') }}</p>
            <p><strong>Statut:</strong> 
                <span class="badge bg-{{ commande.status == 'livre' ? 'success' : (commande.status == 'en_attente' ? 'warning' : 'primary') }}">
                    {{ commande.status }}
                </span>
            </p>
        </div>
    </div>
    
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Produits commandés</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Produit</th>
                        <th>Quantité</th>
                        <th>Prix unitaire</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ligne in commande.ligneCommandes %}
                    <tr>
                        <td>{{ ligne.produit.nom }}</td>
                        <td>{{ ligne.quantite }}</td>
                        <td>{{ ligne.prixUnitaire|number_format(0, ',', ' ') }} FCA</td>
                        <td>{{ (ligne.quantite * ligne.prixUnitaire)|number_format(0, ',', ' ') }} FCA</td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3">Total</th>
                        <th>{{ commande.total|number_format(0, ',', ' ') }} FCA</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    
    <a href="{{ path('admin_commandes') }}" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Retour aux commandes
    </a>
</div>
{% endblock %}

