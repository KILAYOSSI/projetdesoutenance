{% extends 'base.html.twig' %}

{% block title %}Produits - KilysAgri{% endblock %}

{% block body %}
<!-- Toggle Dark/Light Mode -->
<button class="theme-toggle" id="themeToggle" title="Changer le theme">
    <i class="fas fa-moon"></i>
</button>

<!-- Header with Featured Products Carousel (Professional Movies Box Style) -->
<header class="hero-header">
    <div class="hero-slider" id="heroSlider">
        {% if featuredProducts|length > 0 %}
            {% for produit in featuredProducts %}
            <div class="hero-slide" style="background-image: url('{{ produit.image ? asset(produit.image) : 'https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=1920' }}');">
                <div class="hero-overlay"></div>
                <div class="hero-content container">
                    <div class="hero-info">
                        <span class="hero-badge">
                            <i class="fas fa-fire"></i> Produit Populaire
                        </span>
                        <h1 class="hero-title">{{ produit.nom }}</h1>
                        <div class="hero-meta">
                            <span class="hero-price">
                                <i class="fas fa-tag"></i> {{ produit.prix|number_format(0, ',', ' ') }} FCA
                            </span>
                            {% if produit.categorie %}
                            <span class="hero-category">
                                <i class="fas fa-folder"></i> {{ produit.categorie.nom }}
                            </span>
                            {% endif %}
                        </div>
                        <p class="hero-description">{{ produit.description|length > 120 ? produit.description|slice(0, 120) ~ '...' : produit.description }}</p>
                        <div class="hero-actions">
                            <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn-hero-primary">
                                <i class="fas fa-eye"></i> Voir details
                            </a>
                            <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn-hero-secondary">
                                <i class="fas fa-shopping-cart"></i> Ajouter au panier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        {% endif %}
    </div>
    
    <!-- Slider Navigation -->
    <div class="hero-nav">
        <button class="hero-nav-btn prev" onclick="changeSlide(-1)">
            <i class="fas fa-chevron-left"></i>
        </button>
        <div class="hero-dots" id="heroDots"></div>
        <button class="hero-nav-btn next" onclick="changeSlide(1)">
            <i class="fas fa-chevron-right"></i>
        </button>
    </div>
    
    <!-- Gradient Bottom -->
    <div class="hero-gradient-bottom"></div>
</header>

<!-- Search and Filter Section - Modern Style -->
<section class="search-section">
    <div class="container">
        <div class="search-wrapper">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" name="q" placeholder="Rechercher un produit..." class="search-input-modern" value="{{ search|default('') }}">
                <button type="submit" class="btn-search-modern">Rechercher</button>
            </div>
            <div class="filter-tags">
                <select name="categorie" class="filter-select-modern" onchange="window.location.href=this.value">
                    <option value="{{ path('produits_index') }}">Toutes categories</option>
                    {% for categorie in categories %}
                    <option value="{{ path('produits_categorie', {id: categorie.id}) }}" {% if categorie_active is defined and categorie_active and categorie_active.id == categorie.id %}selected{% endif %}>
                        {{ categorie.nom }}
                    </option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>
</section>

<!-- Products by Category -->
<main class="products-main">
    <div class="container">
{% if search is defined and search %}
        <!-- Search Results -->
        <div class="search-results">
            <h2 class="section-title">Resultats de recherche pour "{{ search }}"</h2>
            <p class="results-count">{{ produits|length }} produit(s) trouve(s)</p>
        </div>
        {% endif %}

        {% if categoriesWithProducts|length > 0 %}
            {% for catData in categoriesWithProducts %}
            <section class="category-section">
                <div class="category-header">
                    <div class="category-info">
                        <h2 class="category-title">{{ catData.categorie.nom }}</h2>
                        <span class="product-count">{{ catData.total }} produits</span>
                    </div>
                    <div class="category-actions">
                        <a href="{{ path('produits_categorie', {id: catData.categorie.id}) }}" class="btn btn-outline-category">
                            Voir tous <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                
                <div class="products-grid">
                    {% for produit in catData.produits|slice(0, 8) %}
                    <article class="product-card">
                        <div class="product-image-wrapper">
                            {% if produit.image %}
                                <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="product-image">
                            {% else %}
                                <img src="https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=400" alt="{{ produit.nom }}" class="product-image">
                            {% endif %}
                            <div class="product-overlay">
                                <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn-quick-view">
                                    <i class="fas fa-eye"></i> Voir details
                                </a>
                            </div>
                            {% if produit.quantite <= 0 %}
                            <div class="product-badge badge-out">Rupture</div>
                            {% elseif produit.quantite < 5 %}
                            <div class="product-badge badge-low">Plus que {{ produit.quantite }}</div>
                            {% endif %}
                        </div>
                        <div class="product-content">
                            <span class="product-category">{{ catData.categorie.nom }}</span>
                            <h3 class="product-title">{{ produit.nom }}</h3>
                            <p class="product-description">{{ produit.description|length > 80 ? produit.description|slice(0, 80) ~ '...' : produit.description }}</p>
                            <div class="product-footer">
                                <span class="product-price">{{ produit.prix|number_format(0, ',', ' ') }} FCA</span>
                                <span class="product-quantity">
                                    <i class="fas fa-box"></i> {{ produit.quantite }}
                                </span>
                            </div>
                            <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn btn-product">
                                <i class="fas fa-shopping-cart"></i> Commander
                            </a>
                        </div>
                    </article>
                    {% endfor %}
                </div>
                
                {% if catData.total > 8 %}
                <div class="category-footer">
                    <button class="btn btn-more-products" onclick="loadMoreProducts(this, {{ catData.categorie.id }})">
                        <i class="fas fa-plus"></i> Voir plus de produits
                    </button>
                </div>
                {% endif %}
            </section>
            {% endfor %}
        {% elseif produits|length > 0 %}
        <!-- All Products Grid (when no category is selected) -->
        <section class="all-products-section">
            <div class="section-header">
                <h2 class="section-title">Tous nos produits</h2>
                <span class="products-total">{{ produits|length }} produits disponibles</span>
            </div>
            <div class="products-grid">
                {% for produit in produits %}
                <article class="product-card">
                    <div class="product-image-wrapper">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="product-image">
                        {% else %}
                            <img src="https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=400" alt="{{ produit.nom }}" class="product-image">
                        {% endif %}
                        <div class="product-overlay">
                            <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn-quick-view">
                                <i class="fas fa-eye"></i> Voir details
                            </a>
                        </div>
                        {% if produit.quantite <= 0 %}
                        <div class="product-badge badge-out">Rupture</div>
                        {% elseif produit.quantite < 5 %}
                        <div class="product-badge badge-low">Plus que {{ produit.quantite }}</div>
                        {% endif %}
                    </div>
                    <div class="product-content">
                        {% if produit.categorie %}
                        <span class="product-category">{{ produit.categorie.nom }}</span>
                        {% endif %}
                        <h3 class="product-title">{{ produit.nom }}</h3>
                        <p class="product-description">{{ produit.description|length > 80 ? produit.description|slice(0, 80) ~ '...' : produit.description }}</p>
                        <div class="product-footer">
                            <span class="product-price">{{ produit.prix|number_format(0, ',', ' ') }} FCA</span>
                            <span class="product-quantity">
                                <i class="fas fa-box"></i> {{ produit.quantite }}
                            </span>
                        </div>
                        <a href="{{ path('produits_detail', {id: produit.id}) }}" class="btn btn-product">
                            <i class="fas fa-shopping-cart"></i> Commander
                        </a>
                    </div>
                </article>
                {% endfor %}
            </div>
        </section>
        {% else %}
        <div class="empty-state">
            <i class="fas fa-seedling"></i>
            <h3>Aucun produit disponible</h3>
            <p>Nous n'avons pas encore de produits dans cette categorie.</p>
            <a href="{{ path('produits_index') }}" class="btn btn-empty">
                Voir tous les produits
            </a>
        </div>
        {% endif %}
    </div>
</main>

<style>
/* Theme Toggle */
.theme-toggle {
    position: fixed;
    top: 100px;
    right: 20px;
    z-index: 1000;
    background: linear-gradient(135deg, #198754, #20c997);
    border: none;
    border-radius: 50%;
    width: 50px;
    height: 50px;
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    box-shadow: 0 px rgba(04px 15,0,0,0.2);
    transition: all 0.3s ease;
}

.theme-toggle:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
}

/* PROFFESIONAL HERO CAROUSEL - NETFLIX/MOVIES BOX STYLE */
.hero-header {
    position: relative;
    height: 85vh;
    min-height: 600px;
    max-height: 800px;
    overflow: hidden;
    background: #000;
}

.hero-slider {
    position: relative;
    width: 100%;
    height: 100%;
}

.hero-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 0.8s ease;
}

.hero-slide.active {
    opacity: 1;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.2) 100%),
                linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 50%);
}

.hero-content {
    position: relative;
    z-index: 10;
    height: 100%;
    display: flex;
    align-items: center;
    padding-top: 80px;
}

.hero-info {
    max-width: 600px;
    animation: fadeInUp 0.8s ease forwards;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #e50914, #b20710);
    color: white;
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
}

.hero-title {
    font-size: 4rem;
    font-weight: 900;
    color: white;
    margin-bottom: 20px;
    text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
    line-height: 1.1;
    animation: fadeInUp 0.8s ease 0.3s forwards;
    opacity: 0;
}

.hero-description {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 25px;
    line-height: 1.6;
    text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
    animation: fadeInUp 0.8s ease 0.4s forwards;
    opacity: 0;
}

.hero-meta {
    display: flex;
    gap: 25px;
    margin-bottom: 30px;
    animation: fadeInUp 0.8s ease 0.5s forwards;
    opacity: 0;
}

.hero-price, .hero-category {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #46d369;
    font-size: 1.3rem;
    font-weight: 700;
}

.hero-category {
    color: rgba(255,255,255,0.8);
    font-size: 1rem;
}

.hero-actions {
    display: flex;
    gap: 15px;
    animation: fadeInUp 0.8s ease 0.6s forwards;
    opacity: 0;
}

.btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: white;
    color: black;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
}

.btn-hero-primary:hover {
    background: rgba(255,255,255,0.85);
    transform: scale(1.05);
    color: black;
}

.btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(109,109,110,0.7);
    color: white;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
}

.btn-hero-secondary:hover {
    background: rgba(109,109,110,0.5);
    transform: scale(1.05);
    color: white;
}

.hero-image-mobile {
    display: none;
}

/* Hero Navigation */
.hero-nav {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 20px;
    z-index: 20;
}

.hero-nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
}

.hero-nav-btn:hover {
    background: rgba(255,255,255,0.4);
    transform: scale(1.1);
}

.hero-dots {
    display: flex;
    gap: 8px;
}

.hero-dots .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: all 0.3s ease;
}

.hero-dots .dot.active {
    background: white;
    transform: scale(1.3);
}

/* Gradient Bottom */
.hero-gradient-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to top, #ffffff 0%, transparent 100%);
    pointer-events: none;
}


@media (max-width: 992px) {
    .hero-header { height: 60vh; min-height: 500px; }
    .hero-title { font-size: 2.5rem; }
    .hero-description { font-size: 1rem; }
/* Dark Mode Styles */
}

@media (max-width: 768px) {
    .hero-header { height: 70vh; min-height: 450px; }
    .hero-title { font-size: 2rem; }
    .hero-description { display: none; }
    .hero-meta { flex-direction: column; gap: 10px; }
    .hero-actions { flex-direction: column; }
    .hero-actions a { width: 100%; justify-content: center; }
}

/* Modern Search Section - SEPARATE from header */
.search-section {
    background: white;
    padding: 25px 0;
    margin-top: 0;
    position: relative;
    z-index: 1;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.search-wrapper {
    display: flex;
    gap: 15px;
    align-items: center;
    background: white;
    padding: 8px;
    border-radius: 50px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.15);
}

.search-box {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-left: 20px;
}

.search-box i {
    color: #198754;
    font-size: 1.2rem;
}

.search-input-modern {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    padding: 10px;
    background: transparent;
}

.btn-search-modern {
    background: #198754;
    color: white;
    border: none;
    padding: 12px 25px;
    border-radius: 30px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-search-modern:hover {
    background: #146c43;
    transform: scale(1.02);
}

.filter-select-modern {
    padding: 12px 20px;
    border: none;
    border-left: 1px solid #eee;
    font-size: 1rem;
    background: transparent;
    cursor: pointer;
    outline: none;
    color: #555;
    border-radius: 0 30px 30px 0;
}

.filter-select-modern:focus {
    background: #f8f9fa;
}
body.dark-mode {
    background: #0a0a0a;
    color: #e0e0e0;
}

body.dark-mode .products-header {
    background: linear-gradient(135deg, #1a1a2e 0%, #0f0f1a 100%);
}

body.dark-mode .search-filter-container {
    background: #1a1a1a;
    border-color: #333;
}

body.dark-mode .search-input {
    background: #2a2a2a;
    border-color: #444;
    color: #e0e0e0;
}

body.dark-mode .filter-select {
    background: #2a2a2a;
    border-color: #444;
    color: #e0e0e0;
}

body.dark-mode .category-header {
    background: #1a1a1a;
}

body.dark-mode .category-title {
    color: #20c997;
}

body.dark-mode .product-card {
    background: #1a1a1a;
    border-color: #333;
}

body.dark-mode .product-content {
    background: #1a1a1a;
}

body.dark-mode .product-title {
    color: #e0e0e0;
}

body.dark-mode .product-description {
    color: #aaa;
}

body.dark-mode .product-category {
    color: #20c997;
}

body.dark-mode .btn-product {
    background: #20c997;
}

/* Header */
.products-header {
    position: relative;
    padding: 80px 0 200px;
    background: linear-gradient(135deg, #198754 0%, #0a2913 100%);
    overflow: hidden;
}

.header-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.1) 0%, transparent 60%);
}

.header-content {
    position: relative;
    z-index: 2;
    margin-bottom: 40px;
}

.header-title {
    font-size: 3rem;
    font-weight: 800;
    color: white;
    margin-bottom: 15px;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
}

.header-subtitle {
    font-size: 1.3rem;
    color: rgba(255,255,255,0.9);
}

/* Hero Carousel - Movies Box Style */
.hero-carousel {
    position: relative;
    z-index: 2;
    margin-top: 30px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
}

.carousel-container {
    overflow: hidden;
    border-radius: 20px;
}

.carousel-wrapper {
    overflow: hidden;
}

.carousel-track-full {
    display: flex;
    transition: transform 0.5s ease;
}

.hero-slide {
    flex: 0 0 100%;
    min-width: 100%;
}

.hero-card {
    display: flex;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 50px rgba(0,0,0,0.3);
    margin: 0 10px;
}

.hero-image {
    position: relative;
    width: 45%;
    min-height: 280px;
    overflow: hidden;
}

.hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.hero-gradient {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.1));
}

.hero-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: linear-gradient(135deg, #f39c12, #e74c3c);
    color: white;
    padding: 8px 15px;
    border-radius: 25px;
    font-size: 0.85rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 5px;
}

.hero-content {
    flex: 1;
    padding: 30px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.hero-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 10px;
}

.hero-price {
    font-size: 1.5rem;
    font-weight: 800;
    color: #198754;
    margin-bottom: 15px;
}

.hero-desc {
    color: #6c757d;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 20px;
}

.btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #198754, #20c997);
    color: white;
    padding: 12px 25px;
    border-radius: 25px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    width: fit-content;
}

.btn-hero:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(25, 135, 84, 0.4);
    color: white;
}

/* Carousel Navigation */
.carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.9);
    border: none;
    width: 45px;
    height: 45px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    z-index: 10;
}

.carousel-nav:hover {
    background: white;
    transform: translateY(-50%) scale(1.1);
}

.carousel-nav.prev { left: -20px; }
.carousel-nav.next { right: -20px; }

.carousel-nav i {
    color: #198754;
    font-size: 1.2rem;
}

.carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 20px;
}

.carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: all 0.3s ease;
}

.carousel-dot.active {
    background: #20c997;
    transform: scale(1.2);
}

/* Featured Carousel */
.featured-carousel {
    position: relative;
    z-index: 2;
    margin-top: 30px;
}

.carousel-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding: 20px 10px;
    scroll-behavior: smooth;
}

.carousel-track::-webkit-scrollbar {
    height: 8px;
}

