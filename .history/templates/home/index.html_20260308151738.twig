{% extends 'base.html.twig' %}

{% block title %}Accueil - KilysAgri{% endblock %}

{% block body %}
<style>
/* ==========================================================================
   ROMANTIC HERO SECTION - Design Wow pour KilysAgri
   ========================================================================== */
.hero-romantic {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* Animated Background Shapes */
.hero-romantic::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: 
        radial-gradient(circle at 20% 80%, rgba(25, 135, 84, 0.15) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(32, 201, 151, 0.1) 0%, transparent 40%),
        radial-gradient(circle at 40% 40%, rgba(253, 203, 110, 0.08) 0%, transparent 30%);
    animation: morphBackground 20s ease-in-out infinite;
}

@keyframes morphBackground {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(2%, 2%) rotate(5deg); }
    66% { transform: translate(-2%, 1%) rotate(-3deg); }
}

/* Floating Elements */
.floating-element {
    position: absolute;
    border-radius: 50%;
    opacity: 0.6;
    animation: float 6s ease-in-out infinite;
}

.floating-element:nth-child(1) {
    width: 300px;
    height: 300px;
    top: 10%;
    right: 10%;
    background: linear-gradient(135deg, rgba(25, 135, 84, 0.2), transparent);
    animation-delay: 0s;
}

.floating-element:nth-child(2) {
    width: 200px;
    height: 200px;
    bottom: 20%;
    left: 5%;
    background: linear-gradient(135deg, rgba(253, 203, 110, 0.15), transparent);
    animation-delay: 2s;
}

.floating-element:nth-child(3) {
    width: 150px;
    height: 150px;
    top: 40%;
    left: 30%;
    background: linear-gradient(135deg, rgba(32, 201, 151, 0.2), transparent);
    animation-delay: 4s;
}

@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
}

/* Main Content */
.hero-content {
    position: relative;
    z-index: 10;
    padding: 2rem 0;
}

/* Elegant Badge */
.elegant-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    color: #20c997;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    margin-bottom: 1.5rem;
    animation: slideDown 0.8s ease-out;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.elegant-badge i {
    font-size: 0.75rem;
}

/* Main Title */
.hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    animation: slideUp 0.8s ease-out 0.2s both;
}

.hero-title .highlight {
    background: linear-gradient(135deg, #20c997, #fdcb6e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Subtitle */
.hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
    animation: slideUp 0.8s ease-out 0.4s both;
}

/* CTA Buttons */
.hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    animation: slideUp 0.8s ease-out 0.6s both;
}

.btn-romantic {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 50px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
}

.btn-primary-romantic {
    background: linear-gradient(135deg, #198754, #20c997);
    color: white;
    border: none;
    box-shadow: 0 10px 30px rgba(25, 135, 84, 0.3);
}

.btn-primary-romantic:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(25, 135, 84, 0.4);
    color: white;
}

.btn-outline-romantic {
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
}

.btn-outline-romantic:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
    transform: translateY(-3px);
}

/* Hero Image */
.hero-image-container {
    position: relative;
    animation: slideUp 0.8s ease-out 0.3s both;
}

.hero-image {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: 30px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);
}

.hero-image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    height: 90%;
    background: linear-gradient(135deg, rgba(25, 135, 84, 0.3), rgba(32, 201, 151, 0.2));
    border-radius: 30px;
    filter: blur(40px);
    z-index: -1;
}

/* Scroll Indicator */
.scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    letter-spacing: 2px;
    animation: bounce 2s infinite;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
}

.scroll-indicator i {
    font-size: 1.25rem;
}

/* ==========================================================================
   ROMANTIC FEATURES SECTION
   ========================================================================== */
.features-romantic {
    padding: 6rem 0;
    background: linear-gradient(180deg, #0f3460 0%, #1a1a2e 100%);
    position: relative;
}

.features-romantic::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(32, 201, 151, 0.5), transparent);
}

.section-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #20c997;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 1rem;
}

.section-title-romantic {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
}

.section-subtitle-romantic {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
}

/* Feature Cards */
.feature-card-romantic {
    position: relative;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
}

.feature-card-romantic::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #198754, #20c997, #fdcb6e);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.feature-card-romantic:hover {
    transform: translateY(-8px);
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
}

.feature-card-romantic:hover::before {
    transform: scaleX(1);
}

.feature-icon-romantic {
    width: 70px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(25, 135, 84, 0.2), rgba(32, 201, 151, 0.1));
    border-radius: 20px;
    margin-bottom: 1.5rem;
    font-size: 1.75rem;
    color: #20c997;
}

.feature-title-romantic {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.75rem;
}

.feature-text-romantic {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 0;
}

/* ==========================================================================
   CATEGORIES PREVIEW - ROMANTIC
   ========================================================================== */
.categories-preview {
    padding: 6rem 0;
    background: #1a1a2e;
}

.category-card-romantic {
    position: relative;
    height: 280px;
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-card-romantic:hover {
    transform: scale(1.03);
}

.category-card-romantic img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.category-card-romantic:hover img {
    transform: scale(1.1);
}

.category-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(26, 26, 46, 0.95) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
}

.category-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.25rem;
}

.category-count {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
}

.category-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: white;
    opacity: 0;
    transform: translateX(-10px);
