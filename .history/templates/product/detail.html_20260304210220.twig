{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} - KilysAgri{% endblock %}

{% block body %}
<!-- Header Section -->
<header class="bg-success text-white py-4 shadow-sm">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h3 mb-0">
                    <i class="fas fa-leaf me-2"></i>KilysAgri
                </h1>
                <p class="mb-0 opacity-75">Votre marketplace agricole de confiance</p>
            </div>
            <div class="col-md-6">
                <div class="d-flex justify-content-md-end gap-3 mt-3 mt-md-0">
                    <a href="{{ path('app_home') }}" class="text-white text-decoration-none">
                        <i class="fas fa-home me-1"></i>Accueil
                    </a>
                    <a href="{{ path('produits_index') }}" class="text-white text-decoration-none">
                        <i class="fas fa-store me-1"></i>Catalogue
                    </a>
                    <a href="#" class="text-white text-decoration-none">
                        <i class="fas fa-shopping-cart me-1"></i>Panier
                    </a>
                </div>
        </div>
</header>

<!-- Breadcrumb -->
<nav class="bg-light py-3 border-bottom">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}" class="text-success text-decoration-none">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('produits_index') }}" class="text-success text-decoration-none">Catalogue</a></li>
            {% if produit.categorie %}
                <li class="breadcrumb-item"><a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="text-success text-decoration-none">{{ produit.categorie.nom }}</a></li>
            {% endif %}
            <li class="breadcrumb-item active">{{ produit.nom }}</li>
        </ol>
    </div>
</nav>

<!-- Product Detail Section -->
<main class="py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Product Image -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" 
                                 alt="{{ produit.nom }}" 
                                 class="img-fluid rounded"
                                 style="width: 100%; height: 400px; object-fit: contain;">
                        {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 400px;">
                                <i class="fas fa-image text-muted fa-5x"></i>
                            </div>
                        {% endif %}
                    </div>
                
                <!-- Thumbnail Gallery (placeholder for future) -->
                <div class="row g-2 mt-3">
                    <div class="col-3">
                        <div class="border rounded p-2 text-center">
                            {% if produit.image %}
                                <img src="{{ asset(produit.image) }}" alt="Thumbnail" class="img-fluid rounded" style="height: 60px; object-fit: contain;">
                            {% else %}
                                <i class="fas fa-image text-muted"></i>
                            {% endif %}
                        </div>
                </div>
            
            <!-- Product Info -->
            <div class="col-lg-6">
                <div class="product-info">
                    <!-- Category Badge -->
                    {% if produit.categorie %}
                        <span class="badge bg-success-subtle text-success fs-6 mb-2">
                            <i class="fas fa-tag me-1"></i>{{ produit.categorie.nom }}
                        </span>
                    {% endif %}
                    
                    <!-- Product Title -->
                    <h1 class="display-5 fw-bold mb-3">{{ produit.nom }}</h1>
                    
                    <!-- Stock Status -->
                    <div class="mb-3">
                        {% if produit.quantite > 0 %}
                            <span class="badge bg-success fs-6">
                                <i class="fas fa-check-circle me-1"></i>En stock ({{ produit.quantite }} unités)
                            </span>
                        {% else %}
                            <span class="badge bg-danger fs-6">
                                <i class="fas fa-times-circle me-1"></i>Rupture de stock
                            </span>
                        {% endif %}
                    </div>
                    
                    <!-- Price -->
                    <div class="mb-4">
                        <span class="display-4 text-success fw-bold">{{ produit.prix|number_format(0, ',', ' ') }} €</span>
                        <span class="text-muted fs-6">TTC</span>
                    </div>
                    
                    <!-- Description -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-2">Description</h5>
                        <p class="text-muted lh-lg">{{ produit.description ?: 'Aucune description disponible pour ce produit.' }}</p>
                    </div>
                    
                    <!-- Product Details -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Détails du produit</h5>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block">Prix unitaire</small>
                                    <strong>{{ produit.prix|number_format(0, ',', ' ') }} €</strong>
                                </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block">Quantité disponible</small>
                                    <strong>{{ produit.quantite }} unités</strong>
                                </div>
                            {% if produit.categorie %}
                                <div class="col-6">
                                    <div class="bg-light rounded p-3">
                                        <small class="text-muted d-block">Catégorie</small>
                                        <strong>{{ produit.categorie.nom }}</strong>
                                    </div>
                            {% endif %}
                            <div class="col-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block">Date d'ajout</small>
                                    <strong>{{ produit.createdAt ? produit.createdAt|date('d/m/Y') : 'N/A' }}</strong>
                                </div>
                        </div>
                    
                    <!-- Quantity Selector -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-2">Quantité</h5>
                        <div class="d-flex align-items-center gap-3">
                            <div class="input-group" style="width: 150px;">
                                <button class="btn btn-outline-success" type="button" onclick="decreaseQty()">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="form-control text-center" id="quantity" value="1" min="1" max="{{ produit.quantite }}">
                                <button class="btn btn-outline-success" type="button" onclick="increaseQty()">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <span class="text-muted">Maximum: {{ produit.quantite }}</span>
                        </div>
                    
                    <!-- Action Buttons -->
                    <div class="d-grid gap-3">
                        <button class="btn btn-success btn-lg fw-bold py-3" 
                                {% if produit.quantite == 0 %}disabled{% endif %}
                                onclick="addToCart()">
                            <i class="fas fa-cart-plus me-2"></i>Ajouter au panier
                        </button>
                        <button class="btn btn-outline-success btn-lg fw-bold py-3">
                            <i class="fas fa-heart me-2"></i>Ajouter aux favoris
                        </button>
                    </div>
                    
                    <!-- Shipping Info -->
                    <div class="mt-4 p-3 bg-light rounded">
                        <div class="d-flex align-items-center gap-3">
                            <div class="text-success">
                                <i class="fas fa-truck fa-2x"></i>
                            </div>
                            <div>
                                <strong>Livraison disponible</strong>
                                <p class="mb-0 text-muted small">Livraison dans toute la région sous 3-5 jours ouvrés</p>
                            </div>
                    </div>
            </div>
        
        <!-- Related Products Section -->
        {% if produit.categorie %}
        <div class="mt-5 pt-5">
            <h3 class="fw-bold mb-4">Produits similaires</h3>
            <div class="row g-4">
                <!-- Related products would be loaded here dynamically -->
                <div class="col-12 text-center py-4">
                    <p class="text-muted">Découvrez d'autres produits dans la catégorie {{ produit.categorie.nom }}</p>
                    <a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="btn btn-outline-success">
                        Voir tous les produits
                    </a>
                </div>
        </div>
        {% endif %}
    </div>
</main>

<!-- Footer -->
<footer class="bg-dark text-white py-4 mt-5">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-3 mb-md-0">
                <h5>KilysAgri</h5>
                <p class="text-muted small">Votre plateforme agricole de confiance pour tous vos besoins en produits agricoles de qualité.</p>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <h5>Liens rapides</h5>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-muted text-decoration-none">À propos</a></li>
                    <li><a href="#" class="text-muted text-decoration-none">Contact</a></li>
                    <li><a href="#" class="text-muted text-decoration-none">Conditions générales</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h5>Contact</h5>
                <ul class="list-unstyled text-muted small">
                    <li><i class="fas fa-envelope me-2"></i>contact@kilysagri.com</li>
                    <li><i class="fas fa-phone me-2"></i>+225 00 00 00 00</li>
                    <li><i class="fas fa-map-marker me-2"></i>Côte d'Ivoire</li>
                </ul>
            </div>
        <hr class="bg-secondary">
        <div class="text-center text-muted small">
            &copy; {{ "now"|date("Y") }} KilysAgri. Tous droits réservés.
        </div>
</footer>
{% endblock %}

{% block styles %}
<style>
    .product-info {
        position: sticky;
        top: 20px;
    }
    
    .breadcrumb-item + .breadcrumb-item::before {
        content: ">";
    }
    
    .bg-success-subtle {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }
    
    #quantity:focus {
        border-color: #198754;
        box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.25);
    }
    
    .input-group button:focus {
        box-shadow: none;
    }
</style>
{% endblock %}

{% block javascripts %}
<script>
    function increaseQty() {
        const input = document.getElementById('quantity');
        const max = parseInt(input.max);
        if (parseInt(input.value) < max) {
            input.value = parseInt(input.value) + 1;
        }
    }
    
    function decreaseQty() {
        const input = document.getElementById('quantity');
        if (parseInt(input.value) > 1) {
            input.value = parseInt(input.value) - 1;
        }
    }
    
    function addToCart() {
        const quantity = document.getElementById('quantity').value;
        alert('Produit ajouté au panier ! Quantité: ' + quantity);
    }
</script>
{% endblock %}
</parameter>
</create_file>
