{% extends 'base.html.twig' %}

{% block title %}Inscription - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    .kb-auth-page {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: var(--kb-bg);
    }
    
    .kb-auth-container {
        width: 100%;
        max-width: 500px;
    }
    
    .kb-auth-card {
        background: var(--kb-bg-card);
        border: 1px solid var(--kb-border);
        border-radius: var(--kb-radius-xl);
        padding: 2.5rem;
        box-shadow: var(--kb-shadow-lg);
    }
    
    .kb-auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    
    .kb-auth-logo {
        width: 72px;
        height: 72px;
        background: linear-gradient(135deg, var(--kb-primary) 0%, var(--kb-primary-light) 100%);
        border-radius: var(--kb-radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
        color: white;
    }
    
    .kb-auth-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    
    .kb-auth-subtitle {
        color: var(--kb-text-secondary);
    }
    
    .kb-form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    
    .kb-form-group {
        margin-bottom: 1.25rem;
    }
    
    .kb-form-label {
        display: block;
        font-weight: 600;
        color: var(--kb-text);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    
    .kb-form-input {
        width: 100%;
        padding: 0.875rem 1rem;
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius);
        font-size: 1rem;
        color: var(--kb-text);
        transition: var(--kb-transition);
    }
    
    .kb-form-input:focus {
        outline: none;
        border-color: var(--kb-primary);
        box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.1);
    }
    
    .kb-form-input::placeholder {
        color: var(--kb-text-muted);
    }
    
    .kb-terms {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }
    
    .kb-terms input {
        width: 20px;
        height: 20px;
        accent-color: var(--kb-primary);
        margin-top: 2px;
    }
    
    .kb-terms label {
        font-size: 0.875rem;
        color: var(--kb-text-secondary);
    }
    
    .kb-terms a {
        color: var(--kb-primary);
        font-weight: 600;
        text-decoration: none;
    }
    
    .kb-terms a:hover {
        text-decoration: underline;
    }
    
    .kb-auth-btn {
        width: 100%;
        padding: 1rem;
        font-size: 1rem;
        font-weight: 600;
    }
    
    .kb-auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        color: var(--kb-text-secondary);
    }
    
    .kb-auth-footer a {
        color: var(--kb-primary);
        font-weight: 600;
        text-decoration: none;
    }
    
    .kb-auth-footer a:hover {
        text-decoration: underline;
    }
    
    @media (max-width: 480px) {
        .kb-form-row {
            grid-template-columns: 1fr;
        }
        
        .kb-auth-card {
            padding: 1.5rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="kb-auth-page">
    <div class="kb-auth-container">
        <div class="kb-auth-card animate-fade-in">
            <div class="kb-auth-header">
                <div class="kb-auth-logo">
                    <i class="fas fa-leaf"></i>
                </div>
                <h1 class="kb-auth-title">Créer un compte</h1>
                <p class="kb-auth-subtitle">Rejoignez KilysAgri dès aujourd'hui</p>
            </div>

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="kb-alert kb-alert-error mb-4">
                    <i class="fas fa-exclamation-circle"></i>
                    {{ flash_error }}
                </div>
            {% endfor %}

            {% for flash_success in app.flashes('success') %}
                <div class="kb-alert kb-alert-success mb-4">
                    <i class="fas fa-check-circle"></i>
                    {{ flash_success }}
                </div>
            {% endfor %}

            {{ form_start(registrationForm, {'attr': {'class': 'auth-form'}}) }}
                
                <div class="kb-form-row">
                    <div class="kb-form-group">
                        {{ form_label(registrationForm.nomComplet, 'Nom complet') }}
                        {{ form_widget(registrationForm.nomComplet, {'attr': {'class': 'kb-form-input', 'placeholder': 'Votre nom et prénom'}}) }}
                        {{ form_errors(registrationForm.nomComplet) }}
                    </div>
                    <div class="kb-form-group">
                        {{ form_label(registrationForm.telephone, 'Téléphone') }}
                        {{ form_widget(registrationForm.telephone, {'attr': {'class': 'kb-form-input', 'placeholder': 'Ex: +229 01 00 00 00'}}) }}
                        {{ form_errors(registrationForm.telephone) }}
                    </div>
                
                <div class="kb-form-group">
                    {{ form_label(registrationForm.email, 'Adresse email') }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'kb-form-input', 'placeholder': 'vous@exemple.com'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>
                
                <div class="kb-form-group">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'kb-form-input', 'placeholder': 'Minimum 6 caractères'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>
                
                <div class="kb-form-group">
                    {{ form_label(registrationForm.confirmPassword, 'Confirmer le mot de passe') }}
                    {{ form_widget(registrationForm.confirmPassword, {'attr': {'class': 'kb-form-input', 'placeholder': 'Confirmez votre mot de passe'}}) }}
                    {{ form_errors(registrationForm.confirmPassword) }}
                </div>

                <div class="kb-terms">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <label for="registration_form_agreeTerms">
                        J'accepte les <a href="#">conditions d'utilisation</a> et la <a href="#">politique de confidentialité</a>
                    </label>
                </div>
                {{ form_errors(registrationForm.agreeTerms) }}

                <button type="submit" class="kb-btn kb-btn-primary kb-auth-btn">
                    <i class="fas fa-user-plus"></i>
                    Créer mon compte
                </button>
            {{ form_end(registrationForm) }}

            <div class="kb-auth-footer">
                <p>Déjà un compte? <a href="{{ path('app_login') }}">Se connecter</a></p>
            </div>
    </div>
{% endblock %}
