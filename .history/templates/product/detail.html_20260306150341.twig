{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} - KilysAgri{% endblock %}

{% block body %}

<!-- Breadcrumb -->
<nav style="background: linear-gradient(135deg, #198754 0%, #146c43 100%); padding: 15px 0; margin-top: 70px;">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}" class="text-white text-decoration-none">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('produits_index') }}" class="text-white text-decoration-none">Produits</a></li>
            {% if produit.categorie %}
                <li class="breadcrumb-item"><a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="text-white text-decoration-none">{{ produit.categorie.nom }}</a></li>
            {% endif %}
            <li class="breadcrumb-item active text-white">{{ produit.nom }}</li>
        </ol>
    </div>
</nav>

<!-- Main Content -->
<main style="background: #f8f9fa; padding: 40px 0; min-height: 70vh;">
    <div class="container">
        <div class="row">
            <!-- Image Column -->
            <div class="col-md-6 mb-4">
                <div class="card h-100" style="border-radius: 15px; overflow: hidden;">
                    <div class="card-body d-flex align-items-center justify-content-center p-4" style="min-height: 350px; background: #fff;">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" style="max-width: 100%; max-height: 350px; object-fit: contain; border-radius: 10px;">
                        {% else %}
                            <div class="text-center text-muted">
                                <i class="fas fa-image fa-4x"></i>
                                <p class="mt-2">Pas d'image</p>
                            </div>
                        {% endif %}
                    </div>
            </div>
            
            <!-- Details Column -->
            <div class="col-md-6">
                <div class="card" style="border-radius: 15px;">
                    <div class="card-body p-4">
                        {% if produit.categorie %}
                            <span class="badge bg-success mb-2">{{ produit.categorie.nom }}</span>
                        {% endif %}
                        
                        <h2 style="font-weight: 800; color: #1a1a2e; margin-bottom: 15px;">{{ produit.nom }}</h2>
                        
                        {% if produit.quantite > 0 %}
                            <span class="badge mb-3" style="background: #d4edda; color: #155724; padding: 8px 15px;">
                                <i class="fas fa-check-circle"></i> En stock ({{ produit.quantite }})
                            </span>
                        {% else %}
                            <span class="badge mb-3" style="background: #f8d7da; color: #721c24; padding: 8px 15px;">
                                <i class="fas fa-times-circle"></i> Rupture
                            </span>
                        {% endif %}
                        
                        <h3 style="color: #198754; font-weight: 800; margin-bottom: 20px;">
                            {{ produit.prix|number_format(0, ',', ' ') }} FCA
                        </h3>
                        
                        <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 10px;">Description</h5>
                        <p style="color: #6c757d; line-height: 1.7; margin-bottom: 20px;">
                            {{ produit.description ?: 'Aucune description disponible.' }}
                        </p>
                        
                        <div class="row mb-4">
                            <div class="col-6 mb-2">
                                <div style="background: #f8f9fa; padding: 12px; border-radius: 8px;">
                                    <small class="text-muted d-block">Prix</small>
                                    <strong>{{ produit.prix|number_format(0, ',', ' ') }} FCA</strong>
                                </div>
                            <div class="col-6 mb-2">
                                <div style="background: #f8f9fa; padding: 12px; border-radius: 8px;">
                                    <small class="text-muted d-block">Stock</small>
                                    <strong>{{ produit.quantite }}</strong>
                                </div>
                            {% if produit.categorie %}
                            <div class="col-6">
                                <div style="background: #f8f9fa; padding: 12px; border-radius: 8px;">
                                    <small class="text-muted d-block">Categorie</small>
                                    <strong>{{ produit.categorie.nom }}</strong>
                                </div>
                            {% endif %}
                        </div>
                        
                        {% if produit.quantite > 0 %}
                            <form method="post" action="{{ path('panier_ajouter', {id: produit.id}) }}">
                                <div class="d-flex align-items-center mb-3">
                                    <strong class="me-3">Quantite:</strong>
                                    <button type="button" class="btn btn-outline-success" onclick="var q=document.getElementById('q');q.value=Math.max(1,parseInt(q.value)-1)">
                                        <i class="fas fa-minus"></i>
                                    </button>
                                    <input type="number" id="q" name="quantite" value="1" min="1" max="{{ produit.quantite }}" class="form-control text-center mx-2" style="width: 60px;">
                                    <button type="button" class="btn btn-outline-success" onclick="var q=document.getElementById('q');q.value=Math.min({{ produit.quantite }},parseInt(q.value)+1)">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                                <button type="submit" class="btn btn-success w-100 py-3" style="font-weight: 600; border-radius: 10px;">
                                    <i class="fas fa-cart-plus me-2"></i>Ajouter au panier
                                </button>
                            </form>
                        {% else %}
                            <button class="btn btn-secondary w-100 py-3" disabled style="border-radius: 10px;">
                                <i class="fas fa-ban me-2"></i>Produit indisponible
                            </button>
                        {% endif %}
                        
                        <div class="d-flex align-items-center mt-3 p-3" style="background: #f8f9fa; border-radius: 10px;">
                            <i class="fas fa-truck fa-lg me-3" style="color: #198754;"></i>
                            <div>
                                <strong>Livraison disponible</strong>
                                <p class="mb-0 text-muted small">3-5 jours ouvres</p>
                            </div>
                    </div>
            </div>
        
        {% if produit.categorie %}
        <div class="mt-4">
            <h4 style="font-weight: 700; color: #1a1a2e;">Produits similaires</h4>
            <div class="text-center py-4 bg-white rounded" style="margin-top: 15px;">
                <i class="fas fa-folder-open text-muted fa-2x mb-2 d-block"></i>
                <p class="text-muted">Voir tous les produits dans {{ produit.categorie.nom }}</p>
                <a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="btn btn-success">Voir tout</a>
            </div>
        {% endif %}
    </div>
</main>

{% endblock %}
