{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --kb-primary: #198754;
        --kb-primary-dark: #146c43;
        --kb-accent: #ffd700;
        --kb-dark: #0d1117;
        --kb-dark-secondary: #161b22;
        --kb-card-bg: #21262d;
        --kb-text: #f0f6fc;
        --kb-text-secondary: #8b949e;
        --kb-border: #30363d;
    }

    .kb-page-wrapper {
        background: var(--kb-dark);
        min-height: 100vh;
        padding-top: 70px;
    }

    .kb-breadcrumb {
        background: linear-gradient(135deg, var(--kb-primary) 0%, var(--kb-primary-dark) 100%);
        padding: 1rem 0;
    }

    .kb-breadcrumb a {
        color: rgba(255,255,255,0.8) !important;
        text-decoration: none;
    }

    .kb-breadcrumb a:hover {
        color: white !important;
    }

    .kb-breadcrumb-item.active {
        color: white !important;
    }

    .kb-product-container {
        padding: 3rem 0;
    }

    .kb-product-card {
        background: var(--kb-dark-secondary);
        border: 1px solid var(--kb-border);
        border-radius: 24px;
        overflow: hidden;
    }

    .kb-product-image-section {
        background: var(--kb-card-bg);
        padding: 2rem;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .kb-product-image {
        max-height: 450px;
        width: 100%;
        object-fit: contain;
        border-radius: 16px;
    }

    .kb-product-image-placeholder {
        width: 100%;
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--kb-card-bg);
        border-radius: 16px;
    }

    .kb-product-image-placeholder i {
        font-size: 8rem;
        color: var(--kb-text-secondary);
    }

    .kb-product-info {
        padding: 2.5rem;
    }

    .kb-category-badge {
        display: inline-block;
        background: rgba(25, 135, 84, 0.2);
        color: var(--kb-primary);
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .kb-product-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .kb-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
    }

    .kb-status-in-stock {
        background: rgba(25, 135, 84, 0.2);
        color: #2ecc71;
    }

    .kb-status-out-stock {
        background: rgba(220, 53, 69, 0.2);
        color: #e74c3c;
    }

    .kb-product-price {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--kb-accent);
        margin-bottom: 1.5rem;
    }

    .kb-product-price span {
        font-size: 1rem;
        font-weight: 500;
        color: var(--kb-text-secondary);
    }

    .kb-section-title {
        font-weight: 700;
        color: white;
        margin-bottom: 1rem;
        font-size: 1.1rem;
    }

    .kb-product-description {
        color: var(--kb-text-secondary);
        line-height: 1.8;
        margin-bottom: 2rem;
    }

    .kb-details-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .kb-detail-card {
        background: var(--kb-card-bg);
        padding: 1rem;
        border-radius: 12px;
        border: 1px solid var(--kb-border);
    }

    .kb-detail-card small {
        color: var(--kb-text-secondary);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .kb-detail-card strong {
        display: block;
        color: white;
        font-size: 1.125rem;
        margin-top: 0.25rem;
    }

    .kb-quantity-section {
        margin-bottom: 2rem;
    }

    .kb-quantity-section h5 {
        font-weight: 700;
        color: white;
        margin-bottom: 1rem;
    }

    .kb-quantity-selector {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .kb-qty-btn {
        width: 48px;
        height: 48px;
        border: 2px solid var(--kb-primary);
        background: transparent;
        color: var(--kb-primary);
        border-radius: 12px;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .kb-qty-btn:hover {
        background: var(--kb-primary);
        color: white;
    }

    .kb-qty-input {
        width: 80px;
        height: 48px;
        text-align: center;
        background: var(--kb-card-bg);
        border: 2px solid var(--kb-border);
        border-radius: 12px;
        color: white;
        font-size: 1.125rem;
        font-weight: 600;
    }

    .kb-qty-input:focus {
        outline: none;
        border-color: var(--kb-primary);
    }

    .kb-qty-max {
        color: var(--kb-text-secondary);
        font-size: 0.875rem;
    }

    .kb-add-to-cart-btn {
        width: 100%;
        background: linear-gradient(135deg, var(--kb-primary) 0%, var(--kb-primary-dark) 100%);
        border: none;
        padding: 1rem 2rem;
        border-radius: 12px;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        cursor: pointer;
        text-decoration: none;
    }

    .kb-add-to-cart-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(25, 135, 84, 0.4);
        color: white;
    }

    .kb-add-to-cart-btn:disabled {
        background: var(--kb-border);
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .kb-shipping-info {
        background: var(--kb-card-bg);
        padding: 1.25rem;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
        border: 1px solid var(--kb-border);
    }

    .kb-shipping-icon {
        width: 48px;
        height: 48px;
        background: rgba(25, 135, 84, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--kb-primary);
        font-size: 1.25rem;
    }

    .kb-shipping-text strong {
        color: white;
        display: block;
    }

    .kb-shipping-text p {
        color: var(--kb-text-secondary);
        margin-bottom: 0;
        font-size: 0.875rem;
    }

    .kb-related-section {
        margin-top: 3rem;
        padding: 2rem;
        background: var(--kb-dark-secondary);
        border-radius: 24px;
        border: 1px solid var(--kb-border);
    }

    .kb-related-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1.5rem;
    }

    @media (max-width: 992px) {
        .kb-product-title {
            font-size: 1.75rem;
        }

        .kb-product-price {
            font-size: 2rem;
        }

        .kb-details-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="kb-page-wrapper">
    <!-- Breadcrumb -->
    <nav class="kb-breadcrumb">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('produits_index') }}">Produits</a></li>
                    {% if produit.categorie %}
                        <li class="breadcrumb-item"><a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}">{{ produit.categorie.nom }}</a></li>
                    {% endif %}
                    <li class="breadcrumb-item active" aria-current="page">{{ produit.nom }}</li>
                </ol>
            </nav>
        </div>
    </nav>

    <!-- Product Detail -->
    <main class="kb-product-container">
        <div class="container">
            <div class="row g-4">
                <!-- Product Image -->
                <div class="col-lg-6">
                    <div class="kb-product-card h-100">
                        <div class="kb-product-image-section">
                            {% if produit.image %}
                                <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="kb-product-image">
                            {% else %}
                                <div class="kb-product-image-placeholder">
                                    <i class="fas fa-image"></i>
                                </div>
                            {% endif %}
                        </div>
                </div>
                
                <!-- Product Info -->
                <div class="col-lg-6">
                    <div class="kb-product-card">
                        <div class="kb-product-info">
                            {% if produit.categorie %}
                                <span class="kb-category-badge">
                                    <i class="fas fa-tag me-1"></i>{{ produit.categorie.nom }}
                                </span>
                            {% endif %}
                            
                            <h1 class="kb-product-title">{{ produit.nom }}</h1>
                            
                            <div class="kb-status">
                                {% if produit.quantite > 0 %}
                                    <span class="kb-status-badge kb-status-in-stock">
                                        <i class="fas fa-check-circle"></i> En stock ({{ produit.quantite }} unités)
                                    </span>
                                {% else %}
                                    <span class="kb-status-badge kb-status-out-stock">
                                        <i class="fas fa-times-circle"></i> Rupture de stock
                                    </span>
                                {% endif %}
                            </div>
                            
                            <div class="kb-product-price">
                                {{ produit.prix|number_format(0, ',', ' ') }} <span>FCA</span>
                            </div>
                            
                            <div class="kb-description-section">
                                <h5 class="kb-section-title"><i class="fas fa-align-left me-2"></i>Description</h5>
                                <p class="kb-product-description">{{ produit.description ?: 'Aucune description disponible pour ce produit.' }}</p>
                            </div>
                            
                            <div class="kb-details-grid">
                                <div class="kb-detail-card">
                                    <small>Prix unitaire</small>
                                    <strong>{{ produit.prix|number_format(0, ',', ' ') }} FCA</strong>
                                </div>
                                <div class="kb-detail-card">
                                    <small>Disponibilité</small>
                                    <strong>{{ produit.quantite }} unités</strong>
                                </div>
                                {% if produit.categorie %}
                                <div class="kb-detail-card">
                                    <small>Catégorie</small>
                                    <strong>{{ produit.categorie.nom }}</strong>
                                </div>
                                {% endif %}
                                <div class="kb-detail-card">
                                    <small>Date d'ajout</small>
                                    <strong>{{ produit.createdAt ? produit.createdAt|date('d/m/Y') : 'N/A' }}</strong>
                                </div>
                            
                            {% if produit.quantite > 0 %}
                            <form method="post" action="{{ path('panier_ajouter', {id: produit.id}) }}" id="addToCartForm">
                                <div class="kb-quantity-section">
                                    <h5><i class="fas fa-cubes me-2"></i>Quantité</h5>
                                    <div class="kb-quantity-selector">
                                        <button type="button" class="kb-qty-btn" onclick="updateQty(-1)">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="number" class="kb-qty-input" id="quantity" value="1" min="1" max="{{ produit.quantite }}">
                                        <button type="button" class="kb-qty-btn" onclick="updateQty(1)">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                        <span class="kb-qty-max">Max: {{ produit.quantite }}</span>
                                    </div>
                                <input type="hidden" name="quantite" id="qtyInput" value="1">
                                <button type="submit" class="kb-add-to-cart-btn">
                                    <i class="fas fa-cart-plus"></i>
                                    Ajouter au panier
                                </button>
                            </form>
                            {% else %}
                            <button class="kb-add-to-cart-btn" disabled>
                                <i class="fas fa-ban"></i>
                                Produit indisponible
                            </button>
                            {% endif %}
                            
                            <div class="kb-shipping-info">
                                <div class="kb-shipping-icon">
                                    <i class="fas fa-truck"></i>
                                </div>
                                <div class="kb-shipping-text">
                                    <strong>Livraison disponible</strong>
                                    <p>3-5 jours ouvrés</p>
                                </div>
                        </div>
                </div>
            
            {% if produit.categorie %}
            <div class="kb-related-section">
                <h3 class="kb-related-title">
                    <i class="fas fa-th-large me-2 text-success"></i>Produits similaires
                </h3>
                <div class="text-center py-4" style="background: var(--kb-card-bg); border-radius: 16px;">
                    <i class="fas fa-folder-open text-muted fa-3x mb-3"></i>
                    <p class="text-muted mb-0">Découvrez tous les produits dans {{ produit.categorie.nom }}</p>
                    <a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="btn btn-success mt-3">
                        <i class="fas fa-eye me-2"></i>Voir tout
                    </a>
                </div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script>
    function updateQty(delta) {
        const input = document.getElementById('quantity');
        const qtyInput = document.getElementById('qtyInput');
        const newVal = parseInt(input.value) + delta;
        const max = parseInt(input.max);
        const min = parseInt(input.min);
        
        if (newVal >= min && newVal <= max) {
            input.value = newVal;
            qtyInput.value = newVal;
        }
    }
</script>
{% endblock %}
