<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
        
        <style>
            /* Amélioration de la visibilité du menu dropdown utilisateur */
            .dropdown-menu {
                opacity: 1 !important;
                visibility: visible !important;
                background-color: #ffffff !important;
                border: 1px solid rgba(0, 0, 0, 0.15);
                border-radius: 0.5rem;
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.175) !important;
                padding: 0.5rem 0;
                min-width: 220px;
                margin-top: 0.5rem;
            }
            
            .dropdown-menu .dropdown-item {
                padding: 0.6rem 1.2rem;
                color: #212529 !important;
                font-weight: 500;
                font-size: 0.95rem;
                transition: all 0.2s ease;
                border-radius: 0.25rem;
                margin: 0.1rem 0.4rem;
                width: auto;
            }
            
            .dropdown-menu .dropdown-item:hover {
                background-color: #198754 !important;
                color: #ffffff !important;
            }
            
            .dropdown-menu .dropdown-item.text-danger:hover {
                background-color: #dc3545 !important;
                color: #ffffff !important;
            }
            
            /* Indicateur visible que le dropdown est interactif */
            .nav-link.dropdown-toggle::after {
                display: inline-block;
                margin-left: 0.255em;
                vertical-align: 0.255em;
                content: "";
                border-top: 0.3em solid;
                border-right: 0.3em solid transparent;
                border-left: 0.3em solid transparent;
            }
            
            /* Style pour le lien utilisateur */
            .user-menu-link {
                background-color: rgba(255, 255, 255, 0.1);
                border-radius: 0.375rem;
                padding: 0.375rem 0.75rem;
            }
            
            .user-menu-link:hover {
                background-color: rgba(255, 255, 255, 0.2);
            }
        </style>
    </head>
    <body>
        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-success">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">
                    <i class="fas fa-leaf me-2"></i>KilysAgri
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">ACCUEIL</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('produits_index') }}">PRODUITS</a>
                        </li>
                        {% if app.user and app.user.canSell() %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('vendeur_dashboard') }}">MON ESPACE</a>
                        </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('panier_index') }}">
                                <i class="fas fa-shopping-cart"></i> PANIER
                            </a>
                        </li>
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-menu-link" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle me-1"></i> {{ app.user.email }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    {% if app.user.canSell() %}
                                    <li><a class="dropdown-item" href="{{ path('vendeur_dashboard') }}"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
                                    <li><a class="dropdown-item" href="{{ path('vendeur_produits') }}"><i class="fas fa-boxes me-2"></i>Mes produits</a></li>
                                    <li><a class="dropdown-item" href="{{ path('vendeur_commandes') }}"><i class="fas fa-clipboard-list me-2"></i>Mes commandes</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    {% else %}
                                    <li><a class="dropdown-item" href="{{ path('kyc_submit') }}"><i class="fas fa-store me-2"></i>Devenir vendeur</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    {% endif %}
                                    <li><a class="dropdown-item" href="{{ path('commande_mes_commandes') }}"><i class="fas fa-shopping-bag me-2"></i>Mes achats</a></li>
                                    <li><a class="dropdown-item" href="{{ path('kyc_status') }}"><i class="fas fa-id-card me-2"></i>Mon KYC</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a href="{{ path('app_login') }}" class="btn btn-light btn-sm me-2">CONNEXION</a>
                            </li>
                            <li class="nav-item">
                                <a href="{{ path('app_register') }}" class="btn btn-warning btn-sm">INSCRIPTION</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show m-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% block body %}{% endblock %}
        
        <!-- FOOTER -->
        <footer class="bg-dark text-white py-4 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <h5><strong>KilysAgri</strong></h5>
                        <p class="text-muted small">Votre plateforme agricole de confiance pour connecter producteurs et acheteurs.</p>
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0">
                        <h5>Liens rapides</h5>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('app_home') }}" class="text-muted text-decoration-none">Accueil</a></li>
                            <li><a href="{{ path('produits_index') }}" class="text-muted text-decoration-none">Produits</a></li>
                            <li><a href="{{ path('app_login') }}" class="text-muted text-decoration-none">Connexion</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h5>Contact</h5>
                        <ul class="list-unstyled text-muted small">
                            <li><i class="fas fa-envelope me-2"></i>contact@kilysagri.com</li>
                            <li><i class="fas fa-phone me-2"></i>+229 00 00 00 00</li>
                            <li><i class="fas fa-map-marker me-2"></i>Cotonou, Benin</li>
                        </ul>
                    </div>
                </div>
                <hr class="bg-secondary">
                <div class="text-center text-muted small">&copy; {{ "now"|date("Y") }} KilysAgri. Tous droits réservés.</div>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>

