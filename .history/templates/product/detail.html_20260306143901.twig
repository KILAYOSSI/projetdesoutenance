{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    .product-detail-section { padding: 30px 0 50px; background: #0d1117; }
    .detail-breadcrumb { background: linear-gradient(135deg, #198754 0%, #146c43 100%); padding: 12px 0; margin-top: 70px; }
    .detail-breadcrumb a { color: rgba(255,255,255,0.85) !important; text-decoration: none; }
    .detail-breadcrumb a:hover { color: white !important; }
    .detail-breadcrumb .breadcrumb-item { color: rgba(255,255,255,0.85); }
    .detail-breadcrumb .breadcrumb-item.active { color: white !important; }
    .detail-breadcrumb .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.6); }
    .detail-card { background: #161b22; border: 1px solid #30363d; border-radius: 20px; overflow: hidden; }
    .detail-image-box { background: #21262d; padding: 30px; min-height: 350px; display: flex; align-items: center; justify-content: center; }
    .detail-image-box img { max-width: 100%; max-height: 350px; border-radius: 12px; object-fit: contain; }
    .detail-image-placeholder { width: 100%; height: 300px; display: flex; align-items: center; justify-content: center; background: #21262d; border-radius: 12px; }
    .detail-image-placeholder i { font-size: 6rem; color: #8b949e; opacity: 0.4; }
    .detail-info { padding: 25px; }
    .detail-cat-badge { display: inline-block; background: #198754; color: white; padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; margin-bottom: 12px; }
    .detail-title { font-size: 1.8rem; font-weight: 800; color: white; margin-bottom: 12px; line-height: 1.3; }
    .detail-stock { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 50px; font-weight: 600; font-size: 0.85rem; margin-bottom: 15px; }
    .stock-ok { background: rgba(25, 135, 84, 0.2); color: #20c997; }
    .stock-out { background: rgba(220, 53, 69, 0.2); color: #dc3545; }
    .detail-price { font-size: 2.2rem; font-weight: 800; color: #ffd700; margin-bottom: 20px; }
    .detail-price span { font-size: 0.9rem; font-weight: 500; color: #8b949e; }
    .detail-desc-title { font-size: 1rem; font-weight: 700; color: white; margin-bottom: 10px; }
    .detail-desc { color: #8b949e; line-height: 1.7; margin-bottom: 20px; }
    .detail-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 20px; }
    .detail-grid-item { background: #21262d; padding: 12px; border-radius: 10px; border: 1px solid #30363d; }
    .detail-grid-item small { color: #8b949e; font-size: 0.7rem; text-transform: uppercase; }
    .detail-grid-item strong { display: block; color: white; font-size: 0.95rem; margin-top: 3px; }
    .qty-box { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .qty-btn-mini { width: 38px; height: 38px; border: 2px solid #198754; background: transparent; color: #198754; border-radius: 10px; font-size: 1rem; cursor: pointer; }
    .qty-btn-mini:hover { background: #198754; color: white; }
    .qty-field { width: 60px; height: 38px; text-align: center; border: 2px solid #30363d; border-radius: 10px; background: #21262d; color: white; font-weight: 600; }
    .qty-field:focus { outline: none; border-color: #198754; }
    .add-cart-btn { width: 100%; background: linear-gradient(135deg, #198754 0%, #20c997 100%); color: white; border: none; padding: 14px; border-radius: 12px; font-weight: 700; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .add-cart-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(25, 135, 84, 0.4); }
    .add-cart-btn:disabled { background: #30363d; color: #8b949e; cursor: not-allowed; transform: none; box-shadow: none; }
    .shipping-box { background: #21262d; padding: 14px; border-radius: 12px; display: flex; align-items: center; gap: 12px; margin-top: 18px; border: 1px solid #30363d; }
    .shipping-icon-mini { width: 40px; height: 40px; background: rgba(25, 135, 84, 0.2); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #198754; }
    .shipping-text-mini strong { color: white; display: block; font-size: 0.9rem; }
    .shipping-text-mini p { color: #8b949e; margin: 0; font-size: 0.8rem; }
    .related-box { margin-top: 40px; }
    .related-title-mini { font-size: 1.3rem; font-weight: 700; color: white; margin-bottom: 15px; }
    @media (max-width: 768px) {
        .detail-title { font-size: 1.4rem; }
        .detail-price { font-size: 1.8rem; }
        .detail-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<nav class="detail-breadcrumb">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('produits_index') }}">Produits</a></li>
            {% if produit.categorie %}
                <li class="breadcrumb-item"><a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}">{{ produit.categorie.nom }}</a></li>
            {% endif %}
            <li class="breadcrumb-item active">{{ produit.nom }}</li>
        </ol>
    </div>
</nav>

<main class="product-detail-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="detail-card h-100">
                    <div class="detail-image-box">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}">
                        {% else %}
                            <div class="detail-image-placeholder">
                                <i class="fas fa-image"></i>
                            </div>
                        {% endif %}
                    </div>
            </div>
            
            <div class="col-lg-6">
                <div class="detail-card">
                    <div class="detail-info">
                        {% if produit.categorie %}
                            <span class="detail-cat-badge">
                                <i class="fas fa-tag me-1"></i>{{ produit.categorie.nom }}
                            </span>
                        {% endif %}
                        
                        <h1 class="detail-title">{{ produit.nom }}</h1>
                        
                        <div class="detail-stock {% if produit.quantite > 0 %}stock-ok{% else %}stock-out{% endif %}">
                            <i class="fas {% if produit.quantite > 0 %}fa-check-circle{% else %}fa-times-circle{% endif %}"></i>
                            {% if produit.quantite > 0 %}En stock ({{ produit.quantite }}){% else %}Rupture{% endif %}
                        </div>
                        
                        <div class="detail-price">
                            {{ produit.prix|number_format(0, ',', ' ') }} <span>FCA</span>
                        </div>
                        
                        <div class="detail-desc-title">
                            <i class="fas fa-align-left me-2"></i>Description
                        </div>
                        <p class="detail-desc">{{ produit.description ?: 'Aucune description.' }}</p>
                        
                        <div class="detail-grid">
                            <div class="detail-grid-item">
                                <small>Prix</small>
                                <strong>{{ produit.prix|number_format(0, ',', ' ') }} FCA</strong>
                            </div>
                            <div class="detail-grid-item">
                                <small>Stock</small>
                                <strong>{{ produit.quantite }} unites</strong>
                            </div>
                            {% if produit.categorie %}
                            <div class="detail-grid-item">
                                <small>Categorie</small>
                                <strong>{{ produit.categorie.nom }}</strong>
                            </div>
                            {% endif %}
                            <div class="detail-grid-item">
                                <small>Ajoute le</small>
                                <strong>{{ produit.createdAt ? produit.createdAt|date('d/m/Y') : '-' }}</strong>
                            </div>
                        
                        {% if produit.quantite > 0 %}
                        <form method="post" action="{{ path('panier_ajouter', {id: produit.id}) }}">
                            <div class="qty-box">
                                <button type="button" class="qty-btn-mini" onclick="var q=document.getElementById('qte');q.value=Math.max(1,parseInt(q.value)-1)">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" id="qte" name="quantite" class="qty-field" value="1" min="1" max="{{ produit.quantite }}">
                                <button type="button" class="qty-btn-mini" onclick="var q=document.getElementById('qte');q.value=Math.min({{ produit.quantite }},parseInt(q.value)+1)">
                                    <i class="fas fa-plus"></i>
                                </button>
                                <span style="color: #8b949e; font-size: 0.85rem;">Max: {{ produit.quantite }}</span>
                            </div>
                            
                            <button type="submit" class="add-cart-btn">
                                <i class="fas fa-cart-plus"></i>
                                Ajouter au panier
                            </button>
                        </form>
                        {% else %}
                        <button class="add-cart-btn" disabled>
                            <i class="fas fa-ban"></i>
                            Indisponible
                        </button>
                        {% endif %}
                        
                        <div class="shipping-box">
                            <div class="shipping-icon-mini">
                                <i class="fas fa-truck"></i>
                            </div>
                            <div class="shipping-text-mini">
                                <strong>Livraison disponible</strong>
                                <p>3-5 jours ouvres</p>
                            </div>
                    </div>
            </div>
        
        {% if produit.categorie %}
        <div class="related-box">
            <h3 class="related-title-mini">
                <i class="fas fa-th-large me-2 text-success"></i>Produits similaires
            </h3>
            <div class="text-center py-4" style="background: #161b22; border-radius: 16px; border: 1px solid #30363d;">
                <i class="fas fa-folder-open text-muted fa-2x mb-3 d-block"></i>
                <p class="text-muted mb-3">Voir tous les produits dans {{ produit.categorie.nom }}</p>
                <a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="btn btn-success">
                    <i class="fas fa-eye me-2"></i>Voir tout
                </a>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
