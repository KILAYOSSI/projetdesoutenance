{% extends 'base.html.twig' %}

{% block title %}{% if produit.id %}Modifier{% else %}Ajouter{% endif %} un produit - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-box me-2"></i>{% if produit.id %}Modifier{% else %}Ajouter{% endif %} un produit</h4>
                </div>
                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    
                    <div class="mb-3">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.prix) }}
                            {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.prix) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.quantite) }}
                            {{ form_widget(form.quantite, {'attr': {'class': 'form-control', 'min': 0}}) }}
                            {{ form_errors(form.quantite) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.categorie) }}
                        {{ form_widget(form.categorie, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.categorie) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.imageFile) }}
                        {% if produit.image %}
                        <div class="mb-2">
                            <img src="{{ asset(produit.image) }}" class="rounded" style="max-height: 150px;">
                            <p class="text-muted small">Image actuelle</p>
                        </div>
                        {% endif %}
                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.imageFile) }}
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="{{ path('vendeur_produits') }}" class="btn btn-secondary me-md-2">Annuler</a>
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-save me-2"></i>{% if produit.id %}Enregistrer{% else %}Ajouter{% endif %}
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

