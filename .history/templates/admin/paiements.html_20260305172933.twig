{% extends 'base.html.twig' %}

{% block title %}Paiements - KilysAgri Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-credit-card me-2"></i>Gestion des paiements</h2>
    
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Commande</th>
                            <th>Montant</th>
                            <th>Statut</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for paiement in paiements %}
                        <tr>
                            <td>#{{ paiement.id }}</td>
                            <td>#{{ paiement.commande.id }}</td>
                            <td>{{ paiement.montant|number_format(0, ',', ' ') }} FCA</td>
                            <td>
                                <span class="badge bg-{{ paiement.statut == 'valide' ? 'success' : 'warning' }}">
                                    {{ paiement.statut }}
                                </span>
                            </td>
                            <td>{{ paiement.createdAt|date('d/m/Y H:i') }}</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="text-center">Aucun paiement</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary mt-3">
        <i class="fas fa-arrow-left me-2"></i>Retour au dashboard
    </a>
</div>
{% endblock %}

