{% extends 'base.html.twig' %}

{% block title %}Gestion KYC - KilysAgri Admin{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-id-card-alt me-2"></i>Demandes de vérification d'identité</h2>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning">{{ message }}</div>
    {% endfor %}

    <div class="card shadow">
        <div class="card-body">
            {% if kycs|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-success">
                        <tr>
                            <th>Date</th>
                            <th>Utilisateur</th>
                            <th>Email</th>
                            <th>Type pièce</th>
                            <th>Numéro</th>
                            <th>Photo</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for kyc in kycs %}
                        <tr>
                            <td>{{ kyc.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ kyc.utilisateur.nomComplet|default(kyc.utilisateur.email) }}</td>
                            <td>{{ kyc.utilisateur.email }}</td>
                            <td>
                                {% if kyc.typePiece == 'cni' %}CNI
                                {% elseif kyc.typePiece == 'passeport' %}Passeport
                                {% else %}Permis{% endif %}
                            </td>
                            <td>{{ kyc.numeroPiece }}</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#docsModal{{ kyc.id }}">
                                    <i class="fas fa-image"></i> Voir
                                </button>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a href="{{ path('kyc_admin_validate', {id: kyc.id, action: 'validate'}) }}" class="btn btn-sm btn-success" onclick="return confirm('Valider cette demande ?')">
                                        <i class="fas fa-check"></i> Valider
                                    </a>
                                    <a href="{{ path('kyc_admin_validate', {id: kyc.id, action: 'reject'}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Rejeter cette demande ?')">
                                        <i class="fas fa-times"></i> Rejeter
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="alert alert-info text-center py-4">
                <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                <h4>Aucune demande en attente</h4>
                <p class="mb-0">Toutes les demandes de vérification ont été traitées.</p>
            </div>
            {% endif %}
        </div>
</div>

<!-- Modals for documents -->
{% for kyc in kycs %}
<div class="modal fade" id="docsModal{{ kyc.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Document de {{ kyc.utilisateur.email }}</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12 text-center mb-3">
                        <h6>Photo de la pièce d'identité</h6>
                        {% if kyc.photoPieceRecto %}
                            <img src="{{ asset(kyc.photoPieceRecto) }}" class="img-fluid rounded" style="max-height: 400px;">
                        {% else %}
                            <div class="text-muted">Non fourni</div>
                        {% endif %}
                    </div>
                <div class="alert alert-secondary mt-3">
                    <strong>Type:</strong> {{ kyc.typePiece }} | <strong>Numéro:</strong> {{ kyc.numeroPiece }}
                </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                <a href="{{ path('kyc_admin_validate', {id: kyc.id, action: 'validate'}) }}" class="btn btn-success" onclick="return confirm('Valider cette demande ?')">
                    <i class="fas fa-check"></i> Valider
                </a>
                <a href="{{ path('kyc_admin_validate', {id: kyc.id, action: 'reject'}) }}" class="btn btn-danger" onclick="return confirm('Rejeter cette demande ?')">
                    <i class="fas fa-times"></i> Rejeter
                </a>
            </div>
    </div>
{% endfor %}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
