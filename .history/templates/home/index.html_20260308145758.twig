{% extends 'base.html.twig' %}

{% block title %}Accueil - KilysAgri{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="bg-success text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">Votre Marketplace Agricole</h1>
                <p class="lead mb-4">Achetez et vendez vos produits agricoles en toute simplicité. Des produits frais et de qualité directement des producteurs.</p>
                <a href="{{ path('produits_index') }}" class="btn btn-light btn-lg text-success">
                    <i class="fas fa-compass me-2"></i>Découvrir les produits
                </a>
            </div>
            <div class="col-lg-6 text-center">
                <img src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=500" alt="Produits agricoles" class="img-fluid rounded" style="max-height: 300px;">
            </div>
    </div>
</section>

<!-- Comment ça marche -->
<section class="py-5">
    <div class="container">
        <h2 class="section-title text-center mb-4">Comment ça marche</h2>
        <div class="row text-center">
            <div class="col-md-4">
                <div class="p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-user-plus fa-2x"></i>
                    </div>
                    <h4>1. Créez un compte</h4>
                    <p class="text-muted">Inscrivez-vous gratuitement</p>
                </div>
            <div class="col-md-4">
                <div class="p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-shopping-basket fa-2x"></i>
                    </div>
                    <h4>2. Commandez</h4>
                    <p class="text-muted">Parcourez et achetez vos produits</p>
                </div>
            <div class="col-md-4">
                <div class="p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-truck fa-2x"></i>
                    </div>
                    <h4>3. Recevez</h4>
                    <p class="text-muted">Récupérez votre commande</p>
                </div>
        </div>
</section>

<!-- CTA -->
<section class="py-5 bg-success text-white text-center">
    <div class="container">
        <h2 class="mb-3">Prêt à commencer?</h2>
        <p class="mb-4">Rejoignez KilysAgri</p>
        <a href="{{ path('app_register') }}" class="btn btn-light btn-lg text-success">
            <i class="fas fa-user-plus me-2"></i>Créer un compte
        </a>
    </div>
</section>
{% endblock %}
