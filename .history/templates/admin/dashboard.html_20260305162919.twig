{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - KilysAgri{% endblock %}

{% block stylesheets %}
<style>
    .admin-sidebar {
        min-height: calc(100vh - 70px);
        background: linear-gradient(180deg, #1a1a2e 0%, #2d3436 100%);
        padding: 2rem 0;
    }
    
    .admin-menu-item {
        padding: 1rem 1.5rem;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        display: block;
        transition: all 0.2s ease;
        border-left: 3px solid transparent;
    }
    
    .admin-menu-item:hover, .admin-menu-item.active {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border-left-color: #198754;
    }
    
    .admin-menu-item i {
        width: 25px;
    }
    
    .stat-card {
        border: none;
        border-radius: 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15);
    }
    
    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-gradient-success { background: linear-gradient(135deg, #198754, #20c997); }
    .bg-gradient-primary { background: linear-gradient(135deg, #0d6efd, #0dcaf0); }
    .bg-gradient-warning { background: linear-gradient(135deg, #ffc107, #fd7e14); }
    .bg-gradient-danger { background: linear-gradient(135deg, #dc3545, #ff6b6b); }
    
    .table-admin {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
    }
    
    .table-admin thead {
        background: #f8f9fa;
    }
    
    .table-admin th {
        font-weight: 600;
        color: #495057;
        border-bottom: 2px solid #e9ecef;
    }
    
    .badge-status {
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-weight: 500;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar Admin -->
        <div class="col-md-3 col-lg-2 admin-sidebar">
            <h4 class="text-white px-3 mb-4">
                <i class="fas fa-shield-alt me-2 text-success"></i>Admin
            </h4>
            
            <a href="{{ path('admin_dashboard') }}" class="admin-menu-item active">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <a href="{{ path('admin_users') }}" class="admin-menu-item">
                <i class="fas fa-users"></i> Utilisateurs
            </a>
            <a href="{{ path('admin_produits') }}" class="admin-menu-item">
                <i class="fas fa-boxes"></i> Produits
            </a>
            <a href="{{ path('admin_commandes') }}" class="admin-menu-item">
                <i class="fas fa-shopping-cart"></i> Commandes
            </a>
            <a href="{{ path('kyc_admin_list') }}" class="admin-menu-item">
                <i class="fas fa-id-card"></i> KYC
                {% if kycsEnAttente > 0 %}
                <span class="badge bg-danger float-end">{{ kycsEnAttente }}</span>
                {% endif %}
            </a>
            <a href="{{ path('admin_paiements') }}" class="admin-menu-item">
                <i class="fas fa-money-bill"></i> Paiements
            </a>
            <a href="{{ path('admin_categories') }}" class="admin-menu-item">
                <i class="fas fa-tags"></i> Catégories
            </a>
            <hr class="border-secondary">
            <a href="{{ path('app_home') }}" class="admin-menu-item">
                <i class="fas fa-arrow-left"></i> Retour au site
            </a>
        </div>
        
        <!-- Contenu Principal -->
        <div class="col-md-9 col-lg-10 py-4 px-4" style="background: #f8f9fa;">
            <h2 class="mb-4">
                <i class="fas fa-tachometer-alt me-2 text-success"></i>Dashboard Administrateur
            </h2>
            
            <!-- Cartes de Statistiques -->
            <div class="row g-4 mb-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="card stat-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1">Total Utilisateurs</p>
                                    <h3 class="mb-0">{{ totalUsers }}</h3>
                                </div>
                                <div class="stat-icon bg-gradient-primary text-white">
                                    <i class="fas fa-users"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-sm-6 col-xl-3">
                    <div class="card stat-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1">Producteurs</p>
                                    <h3 class="mb-0">{{ totalProducteurs }}</h3>
                                </div>
                                <div class="stat-icon bg-gradient-success text-white">
                                    <i class="fas fa-store"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-sm-6 col-xl-3">
                    <div class="card stat-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1">Produits</p>
                                    <h3 class="mb-0">{{ totalProduits }}</h3>
                                </div>
                                <div class="stat-icon bg-gradient-warning text-white">
                                    <i class="fas fa-box"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-sm-6 col-xl-3">
                    <div class="card stat-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1">Commandes</p>
                                    <h3 class="mb-0">{{ totalCommandes }}</h3>
                                </div>
                                <div class="stat-icon bg-gradient-danger text-white">
                                    <i class="fas fa-shopping-cart"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Statistiques Détaillées -->
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0">
                            <h5 class="mb-0"><i class="fas fa-chart-pie me-2 text-success"></i>Statut des Commandes</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span>En attente</span>
                                <span class="badge bg-warning">{{ commandesEnAttente }}</span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-warning" style="width: {{ totalCommandes > 0 ? (commandesEnAttente / totalCommandes * 100) : 0 }}%"></div>
                            </div>
                            
                            <div class="d-flex justify-content-between mb-3">
                                <span>En cours</span>
                                <span class="badge bg-primary">{{ commandesEnCours }}</span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-primary" style="width: {{ totalCommandes > 0 ? (commandesEnCours / totalCommandes * 100) : 0 }}%"></div>
                            </div>
                            
                            <div class="d-flex justify-content-between mb-3">
                                <span>Livrées</span>
                                <span class="badge bg-success">{{ commandesLivrees }}</span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-success" style="width: {{ totalCommandes > 0 ? (commandesLivrees / totalCommandes * 100) : 0 }}%"></div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0">
                            <h5 class="mb-0"><i class="fas fa-money-bill-wave me-2 text-success"></i>Revenus</h5>
                        </div>
                        <div class="card-body text-center">
                            <h2 class="text-success mb-1">{{ revenusTotaux|number_format(0, ',', ' ') }} FCA</h2>
                            <p class="text-muted">Revenus totaux des ventes</p>
                            
                            <hr>
                            
                            <div class="row text-center">
                                <div class="col-6">
                                    <h4 class="text-primary">{{ totalPaiements }}</h4>
                                    <small class="text-muted">Paiements</small>
                                </div>
                                <div class="col-6">
                                    <h4 class="text-warning">{{ kycsEnAttente }}</h4>
                                    <small class="text-muted">KYC en attente</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Dernières Commandes -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-shopping-cart me-2 text-success"></i>Dernières Commandes</h5>
                        <a href="{{ path('admin_commandes') }}" class="btn btn-sm btn-outline-success">
                            Voir tout
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-admin mb-0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Client</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for commande in dernieresCommandes %}
                                <tr>
                                    <td>#{{ commande.id }}</td>
                                    <td>{{ commande.utilisateur.email }}</td>
                                    <td>{{ commande.dateCommande|date('d/m/Y') }}</td>
                                    <td>{{ commande.total|number_format(0, ',', ' ') }} FCA</td>
                                    <td>
                                        {% if commande.status == 'en_attente' %}
                                            <span class="badge bg-warning">En attente</span>
                                        {% elseif commande.status == 'en_cours' %}
                                            <span class="badge bg-primary">En cours</span>
                                        {% elseif commande.status == 'livre' %}
                                            <span class="badge bg-success">Livrée</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ commande.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="{{ path('commande_details', {id: commande.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <i class="fas fa-inbox fa-2x mb-2"></i>
                                        <p class="mb-0">Aucune commande</p>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Derniers Utilisateurs -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-users me-2 text-success"></i>Derniers Utilisateurs</h5>
                        <a href="{{ path('admin_users') }}" class="btn btn-sm btn-outline-success">
                            Voir tout
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-admin mb-0">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Rôles</th>
                                    <th>Producteur</th>
                                    <th>Vérifié</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for user in derniersUtilisateurs %}
                                <tr>
                                    <td>{{ user.email }}</td>
                                    <td>
                                        {% for role in user.roles %}
                                            {% if role != 'ROLE_USER' %}
                                                <span class="badge bg-info">{{ role }}</span>
                                            {% endif %}
                                        {% endfor %}
                                    </td>
                                    <td>
                                        {% if user.isVendeur %}
                                            <span class="badge bg-success">Oui</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Non</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if user.isVerified %}
                                            <span class="badge bg-success">Vérifié</span>
                                        {% else %}
                                            <span class="badge bg-warning">En attente</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="{{ path('admin_user_toggle_role', {id: user.id}) }}" class="btn btn-sm btn-outline-warning" title="Changer le rôle">
                                            <i class="fas fa-user-cog"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        Aucun utilisateur
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

