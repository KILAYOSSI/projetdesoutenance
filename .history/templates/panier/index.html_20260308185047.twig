{% extends 'base.html.twig' %}

{% block title %}Panier - KilysAgri{% endblock %}

{% block body %}
<div class="container py-5" style="margin-top: 70px;">
    <h2 class="mb-4"><i class="fas fa-shopping-cart me-2"></i>Mon panier</h2>
    
    {% if produits|length > 0 %}
        <div class="row">
            <div class="col-lg-8">
                {% for item in produits %}
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-2">
                                    {% if item.produit.image %}
                                        <img src="{{ asset(item.produit.image) }}" alt="{{ item.produit.nom }}" class="img-fluid rounded">
                                    {% else %}
                                        <div class="bg-secondary rounded p-3 text-center">
                                            <i class="fas fa-image text-white"></i>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="col-md-4">
                                    <h5 class="mb-1">{{ item.produit.nom }}</h5>
                                    <p class="text-success fw-bold mb-0">{{ item.produit.prix|number_format(0, ',', ' ') }} FCA</p>
                                </div>
                                <div class="col-md-3">
                                    <div class="d-flex align-items-center">
                                        <a href="{{ path('panier_modifier', {id: item.produit.id, quantite: item.quantite - 1}) }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-minus"></i>
                                        </a>
                                        <span class="mx-3">{{ item.quantite }}</span>
                                        <a href="{{ path('panier_modifier', {id: item.produit.id, quantite: item.quantite + 1}) }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-plus"></i>
                                        </a>
                                    </div>
                                <div class="col-md-2 text-end">
                                    <strong>{{ (item.produit.prix * item.quantite)|number_format(0, ',', ' ') }} FCA</strong>
                                </div>
                                <div class="col-md-1 text-end">
                                    <a href="{{ path('panier_supprimer', {id: item.produit.id}) }}" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                        </div>
                {% endfor %}
                
                <a href="{{ path('produits_index') }}" class="btn btn-outline-success">
                    <i class="fas fa-arrow-left me-2"></i>Continuer vos achats
                </a>
            </div>
            
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Récapitulatif</h5>
                        <hr>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Sous-total</span>
                            <span>{{ total|number_format(0, ',', ' ') }} FCA</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Livraison</span>
                            <span class="text-success">Offerte</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total</strong>
                            <strong class="text-success">{{ total|number_format(0, ',', ' ') }} FCA</strong>
                        </div>
                        <a href="{{ path('commande_passer') }}" class="btn btn-success w-100">
                            <i class="fas fa-credit-card me-2"></i>Passer la commande
                        </a>
                    </div>
            </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-shopping-basket fa-5x text-muted mb-4"></i>
            <h3>Votre panier est vide</h3>
            <p class="text-muted">Découvrez nos produits agricoles</p>
            <a href="{{ path('produits_index') }}" class="btn btn-success">
                <i class="fas fa-compass me-2"></i>Découvrir les produits
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
