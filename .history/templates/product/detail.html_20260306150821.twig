{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} - KilysAgri{% endblock %}

{% block body %}

<!-- Breadcrumb -->
<nav style="background: linear-gradient(135deg, #198754 0%, #146c43 100%); padding: 15px 0; margin-top: 70px;">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}" class="text-white text-decoration-none">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('produits_index') }}" class="text-white text-decoration-none">Produits</a></li>
            {% if produit.categorie %}
                <li class="breadcrumb-item"><a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="text-white text-decoration-none">{{ produit.categorie.nom }}</a></li>
            {% endif %}
            <li class="breadcrumb-item active text-white">{{ produit.nom }}</li>
        </ol>
    </div>
</nav>

<!-- Main Content -->
<main style="background: #f8f9fa; padding: 40px 0; min-height: 70vh;">
    <div class="container">
        <div class="row g-4">
            <!-- Image Column -->
            <div class="col-lg-6 mb-4">
                <div class="card h-100 shadow-sm" style="border-radius: 15px; overflow: hidden; border: none;">
                    <div class="card-body d-flex align-items-center justify-content-center p-4" style="min-height: 400px; background: #fff;">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" style="max-width: 100%; max-height: 400px; object-fit: contain; border-radius: 10px;">
                        {% else %}
                            <div class="text-center text-muted">
                                <i class="fas fa-image fa-5x mb-3"></i>
                                <p class="mt-2 fs-5">Pas d'image disponible</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- Details Column -->
            <div class="col-lg-6">
                <div class="card shadow-sm" style="border-radius: 15px; border: none;">
                    <div class="card-body p-4">
                        <!-- Category Badge -->
                        {% if produit.categorie %}
                            <span class="badge bg-success mb-3 fs-6">{{ produit.categorie.nom }}</span>
                        {% endif %}
                        
                        <!-- Product Title -->
                        <h2 style="font-weight: 800; color: #1a1a2e; margin-bottom: 15px;">{{ produit.nom }}</h2>
                        
                        <!-- Stock Status -->
                        {% if produit.quantite > 0 %}
                            <span class="badge mb-3" style="background: #d4edda; color: #155724; padding: 8px 15px; font-size: 0.9rem;">
                                <i class="fas fa-check-circle me-1"></i> En stock ({{ produit.quantite }} disponible(s))
                            </span>
                        {% else %}
                            <span class="badge mb-3" style="background: #f8d7da; color: #721c24; padding: 8px 15px; font-size: 0.9rem;">
                                <i class="fas fa-times-circle me-1"></i> Rupture de stock
                            </span>
                        {% endif %}
                        
                        <!-- Price -->
                        <h3 style="color: #198754; font-weight: 800; margin-bottom: 25px;">
                            {{ produit.prix|number_format(0, ',', ' ') }} FCA
                            <small style="font-size: 0.6em; color: #6c757d; font-weight: 400;">/ unité</small>
                        </h3>
                        
                        <!-- Description -->
                        <div class="mb-4">
                            <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 10px;">
                                <i class="fas fa-align-left me-2 text-success"></i>Description
                            </h5>
                            <p style="color: #6c757d; line-height: 1.8; font-size: 1rem;">
                                {{ produit.description ?: 'Aucune description disponible pour ce produit.' }}
                            </p>
                        </div>
                        
                        <!-- Product Info Grid -->
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div style="background: #f8f9fa; padding: 15px; border-radius: 10px;">
                                    <small class="text-muted d-block mb-1"><i class="fas fa-tag me-1"></i>Prix</small>
                                    <strong class="fs-5">{{ produit.prix|number_format(0, ',', ' ') }} FCA</strong>
                                </div>
                            </div>
                            <div class="col-6">
                                <div style="background: #f8f9fa; padding: 15px; border-radius: 10px;">
                                    <small class="text-muted d-block mb-1"><i class="fas fa-box me-1"></i>Stock</small>
                                    <strong class="fs-5">{{ produit.quantite }}</strong>
                                </div>
                            </div>
                            {% if produit.categorie %}
                            <div class="col-6">
                                <div style="background: #f8f9fa; padding: 15px; border-radius: 10px;">
                                    <small class="text-muted d-block mb-1"><i class="fas fa-folder me-1"></i>Catégorie</small>
                                    <strong class="fs-5">{{ produit.categorie.nom }}</strong>
                                </div>
                            </div>
                            {% endif %}
                            <div class="col-6">
                                <div style="background: #f8f9fa; padding: 15px; border-radius: 10px;">
                                    <small class="text-muted d-block mb-1"><i class="fas fa-calendar me-1"></i>Ajouté le</small>
                                    <strong class="fs-5">{{ produit.createdAt ? produit.createdAt|date('d/m/Y') : '-' }}</strong>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Vendor Info -->
                        {% if produit.utilisateur %}
                        <div class="mb-4 p-3" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-radius: 10px;">
                            <div class="d-flex align-items-center">
                                <div class="bg-white rounded-circle p-2 me-3" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-user text-success fa-lg"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Vendu par</small>
                                    <strong class="fs-6">{{ produit.utilisateur.nom|default('Vendeur') }} {{ produit.utilisateur.prenom|default('') }}</strong>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                        
                        <!-- Add to Cart Form -->
                        {% if produit.quantite > 0 %}
                            <form method="post" action="{{ path('panier_ajouter', {id: produit.id}) }}" class="mb-4">
                                <div class="d-flex align-items-center mb-3">
                                    <strong class="me-3">Quantité:</strong>
                                    <button type="button" class="btn btn-outline-success" onclick="var q=document.getElementById('qte');q.value=Math.max(1,parseInt(q.value)-1); updateTotal()">
                                        <i class="fas fa-minus"></i>
                                    </button>
                                    <input type="number" id="qte" name="quantite" value="1" min="1" max="{{ produit.quantite }}" class="form-control text-center mx-2" style="width: 70px;" onchange="updateTotal()">
                                    <button type="button" class="btn btn-outline-success" onclick="var q=document.getElementById('qte');q.value=Math.min({{ produit.quantite }},parseInt(q.value)+1); updateTotal()">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                                <button type="submit" class="btn btn-success w-100 py-3" style="font-weight: 600; border-radius: 10px; font-size: 1.1rem;">
                                    <i class="fas fa-cart-plus me-2"></i>Ajouter au panier
                                </button>
                            </form>
                        {% else %}
                            <button class="btn btn-secondary w-100 py-3 mb-4" disabled style="border-radius: 10px; font-size: 1.1rem;">
                                <i class="fas fa-ban me-2"></i>Produit indisponible
                            </button>
                        {% endif %}
                        
                        <!-- Delivery Info -->
                        <div class="d-flex align-items-center p-3" style="background: #f8f9fa; border-radius: 10px;">
                            <i class="fas fa-truck fa-lg me-3" style="color: #198754;"></i>
                            <div>
                                <strong>Livraison disponible</strong>
                                <p class="mb-0 text-muted small">3-5 jours ouvrés</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Similar Products Section -->
        {% if similarProducts is defined and similarProducts|length > 0 %}
        <div class="mt-5">
            <h4 style="font-weight: 700; color: #1a1a2e; margin-bottom: 20px;">
                <i class="fas fa-random me-2 text-success"></i>Produits similaires
            </h4>
            <div class="row g-4">
                {% for similar in similarProducts %}
                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 shadow-sm" style="border-radius: 15px; border: none; transition: transform 0.3s;">
                        <div class="card-body d-flex align-items-center justify-content-center p-3" style="min-height: 180px; background: #fff;">
                            {% if similar.image %}
                                <img src="{{ asset(similar.image) }}" alt="{{ similar.nom }}" style="max-width: 100%; max-height: 160px; object-fit: contain; border-radius: 8px;">
                            {% else %}
                                <i class="fas fa-image text-muted fa-3x"></i>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-white border-0" style="border-radius: 0 0 15px 15px;">
                            <h6 class="mb-1 text-truncate" style="font-weight: 600;">{{ similar.nom }}</h6>
                            <p class="text-success fw-bold mb-2">{{ similar.prix|number_format(0, ',', ' ') }} FCA</p>
                            <a href="{{ path('produits_detail', {id: similar.id}) }}" class="btn btn-outline-success btn-sm w-100">Voir</a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
        
        {% if produit.categorie %}
        <div class="mt-4 text-center">
            <a href="{{ path('produits_categorie', {id: produit.categorie.id}) }}" class="btn btn-outline-success">
                <i class="fas fa-eye me-2"></i>Voir tous les produits dans {{ produit.categorie.nom }}
            </a>
        </div>
        {% endif %}
    </div>
</main>

{% endblock %}
