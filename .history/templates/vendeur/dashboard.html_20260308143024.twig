{% extends 'base.html.twig' %}

{% block title %}Dashboard Vendeur - KilysAgri{% endblock %}

{% block body %}
<div class="container py-4" style="margin-top: 70px;">
    <h2 class="mb-4"><i class="fas fa-store me-2"></i>Mon Espace Vendeur</h2>
    
    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-box fa-2x text-success mb-2"></i>
                    <h3>{{ produits|length }}</h3>
                    <p class="text-muted mb-0">Produits</p>
                </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-shopping-bag fa-2x text-primary mb-2"></i>
                    <h3>{{ commandes|length }}</h3>
                    <p class="text-muted mb-0">Commandes</p>
                </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                    <h3>{{ commandesConfirmed|default(0) }}</h3>
                    <p class="text-muted mb-0">Validées</p>
                </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    {% if app.user.isKycValidated %}
                        <i class="fas fa-check fa-2x text-success mb-2"></i>
                        <h3 class="text-success">Validé</h3>
                    {% else %}
                        <i class="fas fa-clock fa-2x text-warning mb-2"></i>
                        <h3 class="text-warning">En attente</h3>
                    {% endif %}
                    <p class="text-muted mb-0">Statut KYC</p>
                </div>
        </div>
    
    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-bolt me-2"></i>Actions rapides</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a href="{{ path('vendeur_produit_new') }}" class="btn btn-outline-success w-100">
                                <i class="fas fa-plus me-2"></i>Ajouter produit
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="{{ path('vendeur_produits') }}" class="btn btn-outline-success w-100">
                                <i class="fas fa-boxes me-2"></i>Mes produits
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="{{ path('vendeur_commandes') }}" class="btn btn-outline-success w-100">
                                <i class="fas fa-shopping-bag me-2"></i>Commandes
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="{{ path('kyc_status') }}" class="btn btn-outline-success w-100">
                                <i class="fas fa-id-card me-2"></i>Mon KYC
                            </a>
                        </div>
                </div>
        </div>
    
    <!-- Recent Orders -->
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-clock me-2"></i>Commandes récentes</h5>
        </div>
        <div class="card-body">
            {% if commandes|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Commande</th>
                                <th>Client</th>
                                <th>Montant</th>
                                <th>Statut</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for commande in commandes|slice(0, 5) %}
                                <tr>
                                    <td><strong>#{{ commande.id }}</strong></td>
                                    <td>{{ commande.utilisateur.nomComplet|default(commande.utilisateur.email) }}</td>
                                    <td><strong>{{ commande.montantTotal|number_format(0, ',', ' ') }} FCA</strong></td>
                                    <td>
                                        <span class="badge bg-{% if commande.status == 'confirmed' %}success{% elseif commande.status == 'pending' %}warning{% else %}info{% endif %}">
                                            {{ commande.status }}
                                        </span>
                                    </td>
                                    <td>{{ commande.createdAt ? commande.createdAt|date('d/m/Y') : '-' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-center text-muted py-4">Aucune commande pour le moment</p>
            {% endif %}
        </div>
</div>
{% endblock %}
