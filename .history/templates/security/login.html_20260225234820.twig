{% extends 'base.html.twig' %}

{% block title %}Connexion - KilysAgri{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <!-- Animated Background -->
    <div class="auth-background">
        <div class="bg-shape shape-1"></div>
        <div class="bg-shape shape-2"></div>
        <div class="bg-shape shape-3"></div>
        <div class="bg-grid"></div>
    </div>

    <div class="auth-container-modern">
        <!-- Brand Section -->
        <div class="auth-brand">
            <div class="brand-logo">
                <span class="logo-icon">K</span>
                <div class="logo-glow"></div>
            </div>
            <h1>Bon retour</h1>
            <p>Connectez-vous pour continuer votre expérience agricole intelligente</p>
        </div>

        <!-- Login Form -->
        <form method="post" class="auth-form-modern">
            {% if error %}
                <div class="alert-modern alert-error">
                    <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {% if app.user %}
                <div class="alert-modern alert-info">
                    <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    <span>Connecté en tant que {{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class="alert-link">Déconnexion</a>
                </div>
            {% endif %}

            <div class="form-group-modern">
                <label for="inputEmail">Email</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control-modern" autocomplete="email" required autofocus placeholder="exemple@email.com">
                </div>
                <div class="input-highlight"></div>
            </div>

            <div class="form-group-modern">
                <label for="inputPassword">Mot de passe</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input type="password" name="password" id="inputPassword" class="form-control-modern" autocomplete="current-password" required placeholder="••••••••">
                    <button type="button" class="password-toggle" onclick="togglePassword()">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="input-highlight"></div>
            </div>

            <div class="form-options">
                <label class="checkbox-modern">
                    <input type="checkbox" name="_remember_me">
                    <span class="checkmark"></span>
                    <span class="checkbox-label">Se souvenir de moi</span>
                </label>
                <a href="#" class="forgot-link">Mot de passe oublié?</a>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="btn-submit-modern" type="submit">
                <span>Se connecter</span>
                <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
                <div class="btn-glow"></div>
            </button>
        </form>

        <!-- Divider -->
        <div class="auth-divider-modern">
            <span>ou</span>
        </div>

        <!-- Social Login -->
        <div class="social-login">
            <button class="btn-social btn-google-modern">
                <svg class="google-icon" viewBox="0 0 24 24">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span>Continuer avec Google</span>
            </button>
        </div>

        <!-- Register Link -->
        <div class="auth-footer-modern">
            <p>Pas encore de compte? <a href="{{ path('app_register') }}" class="register-link">Créer un compte</a></p>
        </div>
    </div>

    <!-- Floating Elements -->
    <div class="floating-element fe-1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
        </svg>
    </div>
    <div class="floating-element fe-2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
        </svg>
    </div>
</div>

<script>
function togglePassword() {
    const passwordInput = document.getElementById('inputPassword');
    const toggleBtn = document.querySelector('.password-toggle');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        toggleBtn.classList.add('active');
    } else {
        passwordInput.type = 'password';
        toggleBtn.classList.remove('active');
    }
}
</script>
{% endblock %}
